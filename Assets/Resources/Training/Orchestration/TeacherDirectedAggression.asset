  m_Script: {fileID: 11500000, guid: 3fcb78a4161640028c54450115bec05a, type: 3}
  m_Name: TeacherDirectedAggression
  m_EditorClassIdentifier: AdieLab.TeacherTraining::AdieLab.TeacherTraining.CrisisOrchestrationScenarioAsset
  scenarioId: teacher-directed-aggression-v1
  displayName: "\uAD50\uC0AC \uB300\uC0C1 \uC695\uC124\xB7\uBB3C\uAC74 \uB358\uC9C0\uAE30\uC640
    \uD300 \uB300\uC751"
  learningPurpose: "\uAD50\uC0AC\uAC00 \uC790\uC2E0\uC758 \uBD84\uB178\uB098 \uB2F9\uD669\uC744
    \uC228\uAE30\uAC70\uB098 \uD3C9\uAC00\uBC1B\uC9C0 \uC54A\uC73C\uBA74\uC11C \uD310\uB2E8
    \uC5EC\uC720\uB97C \uD655\uBCF4\uD558\uACE0, \uD559\uC0DD\xB7\uD559\uAE09\xB7\uAD50\uC0AC\uC758
    \uC548\uC804\uC744 \uD568\uAED8 \uD310\uB2E8\uD558\uC5EC \uC9C0\uC6D0 \uC694\uCCAD,
    \uC5ED\uD560 \uC778\uACC4, \uAE30\uB85D\uACFC \uD68C\uBCF5\uAE4C\uC9C0 \uC218\uD589\uD55C\uB2E4."
  context: "4\uAD50\uC2DC \uAC1C\uBCC4 \uACFC\uC81C \uC2DC\uAC04. \uACFC\uC81C\uAC00
    \uC5B4\uB835\uB2E4\uACE0 \uB9D0\uD558\uB358 \uD559\uC0DD\uC774 \uAD50\uC0AC\uC758
    \uC7AC\uC548\uB0B4 \uC9C1\uD6C4 \uD544\uD1B5\uC744 \uBC14\uB2E5 \uCABD\uC73C\uB85C
    \uB358\uC9C0\uACE0 \uD070 \uBAA9\uC18C\uB9AC\uB85C \u2018\uC120\uC0DD\uB2D8\uB3C4
    \uB0B4 \uB9D0 \uC548 \uB4E3\uC796\uC544\uC694!\u2019\uB77C\uACE0 \uB9D0\uD55C\uB2E4.
    \uC55E\uC904 \uD559\uC0DD \uB124 \uBA85\uC774 \uBA48\uCDB0\uC11C \uC0C1\uD669\uC744
    \uBCF4\uACE0 \uC788\uACE0, \uD55C \uD559\uC0DD\uC740 \uC758\uC790\uB97C \uB4A4\uB85C
    \uBC00\uBA70 \uD1B5\uB85C \uCABD\uC73C\uB85C \uC6C0\uC9C1\uC778\uB2E4."
  safetyBoundary: "\uC774 \uC2DC\uB098\uB9AC\uC624\uB294 \uAD50\uC0AC\uAC00 \uD559\uC0DD\uC744
    \uC2E0\uCCB4\uC801\uC73C\uB85C \uC81C\uC555\uD558\uAC70\uB098 \uD63C\uC790 \uAC15\uC81C
    \uBD84\uB9AC\uD558\uB294 \uC5F0\uC2B5\uC774 \uC544\uB2C8\uB2E4. \uC2E4\uC81C
    \uD559\uAD50\uC758 \uC2B9\uC778\uB41C \uC548\uC804 \uC808\uCC28\uC640 \uC5ED\uD560
    \uCCB4\uACC4\uB97C \uC6B0\uC120\uD558\uBA70, \uC989\uAC01\uC801 \uC704\uD5D8\uC774
    \uC788\uC73C\uBA74 \uD559\uC2B5 \uBAA9\uD45C\uBCF4\uB2E4 \uD604\uC7A5 \uC548\uC804
    \uC9C0\uCE68\uC744 \uB530\uB978\uB2E4."
  initialState:
    phase: 0
    teacher:
      arousal: 0.82
      regulationCapacity: 0.28
      physicalSafety: 0.42
      perceivedSupport: 0.12
      responseConfidence: 0.38
    classroom:
      focalStudentRisk: 0.82
      peerDistress: 0.68
      noise: 0.64
      peersInUnsafeArea: 4
      learningContinuity: 0.4
    support:
      colleagueAvailable: 1
      administratorAvailable: 1
      counselorAvailable: 1
      colleagueResponse: 0
      administratorResponse: 0
    objectiveRecordCompleted: 0
    recoveryPlanCompleted: 0
  beats:
  - beatId: 01.teacher-state
    phase: 0
    title: "\uB0B4 \uC0C1\uD0DC\uB97C \uBA3C\uC800 \uC54C\uC544\uCC28\uB9AC\uAE30"
    situation: "\uD559\uC0DD\uC758 \uB9D0\uACFC \uBB3C\uAC74\uC774 \uB5A8\uC5B4\uC9C0\uB294
      \uC18C\uB9AC\uC5D0 \uC21C\uAC04\uC801\uC73C\uB85C \uC2EC\uC7A5\uC774 \uBE68\uB77C\uC9C0\uACE0
      \uD654\uAC00 \uC62C\uB77C\uC628\uB2E4."
    privateTeacherPrompt: "\uC9C0\uAE08 \uB290\uB07C\uB294 \uAC10\uC815\uC5D0\uB294
      \uC810\uC218\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4. \uC774 \uC0C1\uD0DC\uC5D0\uC11C
      \uC5B4\uB5A4 \uD589\uB3D9\uC744 \uC120\uD0DD\uD558\uBA74 \uD559\uC0DD\uACFC
      \uB098, \uD559\uAE09\uC758 \uC548\uC804\uC5D0 \uB3C4\uC6C0\uC774 \uB420\uAE4C\uC694?"
    observableSignals: "\uD559\uC0DD\uC758 \uC5B4\uAE68\uAC00 \uC62C\uB77C\uAC00
      \uC788\uACE0 \uC190\uC5D0 \uD798\uC774 \uB4E4\uC5B4\uAC00 \uC788\uB2E4. \uC8FC\uBCC0
      \uD559\uC0DD\uB4E4\uC774 \uB9D0\uC744 \uBA48\uCD94\uACE0 \uCCD0\uB2E4\uBCF8\uB2E4."
    facilitatorNote: "\uAD50\uC0AC \uAC10\uC815\uC744 \uC5B5\uC555\uD558\uAC70\uB098
      \uB3C4\uB355\uC801\uC73C\uB85C \uD3C9\uAC00\uD558\uC9C0 \uC54A\uB294\uB2E4.
      \uD310\uB2E8 \uC5EC\uC720\uB97C \uD655\uBCF4\uD558\uB294 \uAD00\uCC30 \uAC00\uB2A5\uD55C
      \uD589\uB3D9\uC744 \uD53C\uB4DC\uBC31\uD55C\uB2E4."
    debriefPrompt: "\uB098\uB294 \uC5B4\uB5A4 \uC2E0\uCCB4 \uC2E0\uD638\uB97C \uC54C\uC544\uCC28\uB838\uACE0,
      \uADF8\uAC83\uC774 \uB2E4\uC74C \uD310\uB2E8\uC5D0 \uC5B4\uB5A4 \uC601\uD5A5\uC744
      \uC8FC\uC5C8\uB294\uAC00?"
    completionAction: 0
    options:
    - action: 0
      label: "\uD55C \uD638\uD761 \uBA48\uCD94\uACE0 \uAC70\uB9AC\xB7\uCD9C\uAD6C\xB7\uC8FC\uBCC0
        \uD559\uC0DD\uC744 \uD655\uC778\uD55C\uB2E4"
      operationalScript: "\uC18D\uC73C\uB85C \u2018\uD654\uAC00 \uC62C\uB77C\uC654\uB2E4\u2019\uB97C
        \uD655\uC778\uD558\uACE0 \uD55C \uAC78\uC74C \uC606\uC73C\uB85C \uC774\uB3D9\uD574
        \uC190, \uD1B5\uB85C, \uC8FC\uBCC0 \uD559\uC0DD \uC704\uCE58\uB97C \uBCF8\uB2E4."
      rationale: "\uAC10\uC815\uC744 \uC5C6\uC560\uB294 \uAC83\uC774 \uC544\uB2C8\uB77C
        \uCDA9\uB3D9\uC801\uC778 \uB9DE\uB300\uC751 \uC804\uC5D0 \uD310\uB2E8\uD560
        \uC2DC\uAC04\uC744 \uD655\uBCF4\uD55C\uB2E4."
    - action: 1
      label: "\uC989\uC2DC \uD070 \uBAA9\uC18C\uB9AC\uB85C \uD589\uB3D9\uC744 \uC81C\uC9C0\uD55C\uB2E4"
      operationalScript: "\u2018\uC9C0\uAE08 \uB2F9\uC7A5 \uADF8\uB9CC\uD574!\u2019\uB77C\uACE0
        \uBC18\uC751\uD55C\uB2E4."
      rationale: "\uAD50\uC0AC\uC640 \uD559\uC0DD\uC758 \uAC01\uC131\uC774 \uBAA8\uB450
        \uB192\uC744 \uB54C \uC989\uAC01\uC801\uC778 \uB9DE\uB300\uC751\uC740 \uC0C1\uD638
        \uACA9\uD654\uB97C \uD0A4\uC6B8 \uC218 \uC788\uB2E4."
  - beatId: 02.peer-safety
    phase: 1
    title: "\uD559\uAE09 \uC804\uCCB4\uC758 \uC548\uC804 \uD655\uBCF4"
    situation: "\uCD08\uC810\uD559\uC0DD\uB9CC \uBC14\uB77C\uBCF4\uB294 \uB3D9\uC548
      \uC55E\uC904 \uD559\uC0DD \uB124 \uBA85\uC774 \uAC00\uAE4C\uC6B4 \uC704\uCE58\uC5D0
      \uB0A8\uC544 \uC788\uB2E4."
    privateTeacherPrompt: "\uC218\uC5C5\uC744 \uACC4\uC18D\uD558\uB294 \uAC83\uACFC
      \uC8FC\uBCC0 \uD559\uC0DD\uC744 \uC774\uB3D9\uC2DC\uD0A4\uB294 \uAC83 \uC911
      \uC9C0\uAE08 \uBB34\uC5C7\uC774 \uC6B0\uC120\uC778\uAC00?"
    observableSignals: "\uD55C \uD559\uC0DD\uC774 \uC758\uC790\uB97C \uBC00\uACE0
      \uD1B5\uB85C\uB85C \uB098\uC624\uBA70 \uB2E4\uB978 \uD559\uC0DD\uC740 \uD544\uD1B5\uC744
      \uC8FC\uC6B0\uB824 \uD55C\uB2E4."
    facilitatorNote: "\uCD08\uC810\uD559\uC0DD\uC744 \uACF5\uAC1C\uC801\uC73C\uB85C
      \uB458\uB7EC\uC2F8\uC9C0 \uC54A\uC73C\uBA74\uC11C \uB610\uB798\uC758 \uC548\uC804\uACFC
      \uAD6C\uACBD \uC790\uADF9\uC744 \uC904\uC774\uB294 \uC120\uD0DD\uC744 \uB2E4\uB8EC\uB2E4."
    debriefPrompt: "\uB098\uB294 \uCD08\uC810\uD559\uC0DD \uC678\uC5D0 \uB204\uAD6C\uC758
      \uC548\uC804\uC744 \uD655\uC778\uD588\uB294\uAC00?"
    completionAction: 2
    options:
    - action: 2
      label: "\uC8FC\uBCC0 \uD559\uC0DD\uC5D0\uAC8C \uC9E7\uACE0 \uC911\uB9BD\uC801\uC778
        \uC774\uB3D9 \uC9C0\uC2DC\uB97C \uD55C\uB2E4"
      operationalScript: "\u2018\uC55E\uC904\uC740 \uC120\uC0DD\uB2D8 \uCC45\uC0C1
        \uC606 \uBAA8\uB460\uC73C\uB85C \uC870\uC6A9\uD788 \uC774\uB3D9\uD574 \uC8FC\uC138\uC694.
        \uBB3C\uAC74\uC740 \uADF8\uB300\uB85C \uB450\uC138\uC694.\u2019"
      rationale: "\uC218\uC5C5 \uC9C0\uC18D\uBCF4\uB2E4 \uC548\uC804\uC744 \uC6B0\uC120\uD558\uACE0
        \uCD08\uC810\uD559\uC0DD\uC744 \uAD6C\uACBD\uD558\uB294 \uC9D1\uB2E8 \uC790\uADF9\uC744
        \uC904\uC778\uB2E4."
    - action: 7
      label: "\uD604\uC7A5\uC5D0\uC11C \uBC14\uB85C \uAE30\uB85D\uC744 \uC2DC\uC791\uD55C\uB2E4"
      operationalScript: "\uD734\uB300\uAE30\uAE30\uB97C \uAEBC\uB0B4 \uC0AC\uAC74
        \uB0B4\uC6A9\uC744 \uC785\uB825\uD55C\uB2E4."
      rationale: "\uC704\uD5D8\uC774 \uB0A8\uC544 \uC788\uB294 \uB3D9\uC548 \uAE30\uB85D\uC744
        \uC2DC\uC791\uD558\uBA74 \uC8FC\uBCC0 \uD559\uC0DD\uACFC \uD604\uC7A5 \uBCC0\uD654\uB97C
        \uB193\uCE60 \uC218 \uC788\uB2E4."
  - beatId: 03.help-request
    phase: 2
    title: "\uAD6C\uCCB4\uC801\uC73C\uB85C \uB3C4\uC6C0 \uC694\uCCAD\uD558\uAE30"
    situation: "\uD559\uC0DD\uACFC \uD559\uAE09\uC744 \uB3D9\uC2DC\uC5D0 \uAD00\uCC30\uD558\uAE30
      \uC5B4\uB835\uACE0 \uAD50\uC0AC\uC758 \uBB3C\uB9AC\uC801 \uC548\uC804\uAC10\uB3C4
      \uB0AE\uB2E4."
    privateTeacherPrompt: "\uD63C\uC790 \uD574\uACB0\uD558\uB824\uB294 \uAC83\uC774
      \uCC45\uC784\uAC10\uC778\uC9C0, \uC9C0\uC6D0 \uC694\uCCAD\uC744 \uB2A6\uCD94\uB294
      \uAC83\uC778\uC9C0 \uD310\uB2E8\uD574 \uBCF4\uC138\uC694."
    observableSignals: "\uD559\uC0DD\uC740 \uAD50\uC2E4 \uB4A4\uCABD\uC73C\uB85C
      \uC6C0\uC9C1\uC774\uB824 \uD558\uACE0 \uC8FC\uBCC0 \uD559\uC0DD\uC758 \uC8FC\uC758\uAC00
      \uACC4\uC18D \uC3E0\uB9B0\uB2E4."
    facilitatorNote: "\uB3C4\uC6C0 \uC694\uCCAD\uC740 \uC2E4\uD328\uAC00 \uC544\uB2C8\uB2E4.
      \uC704\uCE58, \uC704\uD5D8, \uD544\uC694\uD55C \uC5ED\uD560\uC744 \uC9E7\uACE0
      \uAD6C\uCCB4\uC801\uC73C\uB85C \uC804\uB2EC\uD558\uAC8C \uD55C\uB2E4."
    debriefPrompt: "\uB098\uB294 \uB204\uAD6C\uC5D0\uAC8C \uBB34\uC5C7\uC744 \uD574
      \uB2EC\uB77C\uACE0 \uC694\uCCAD\uD588\uB294\uAC00?"
    completionAction: 3
    options:
    - action: 3
      label: "\uB3D9\uB8CC \uAD50\uC0AC\uC5D0\uAC8C \uD559\uAE09 \uC548\uC804 \uC9C0\uC6D0\uC744
        \uC694\uCCAD\uD55C\uB2E4"
      operationalScript: "\u20184\uD559\uB144 2\uBC18\uC785\uB2C8\uB2E4. \uD559\uC0DD\uC774
        \uBB3C\uAC74\uC744 \uB358\uC84C\uACE0 \uC8FC\uBCC0 \uD559\uC0DD \uC774\uB3D9\uC774
        \uD544\uC694\uD569\uB2C8\uB2E4. \uD559\uAE09 \uD559\uC0DD\uC744 \uC778\uC194\uD558\uACE0
        \uD1B5\uB85C\uB97C \uD655\uBCF4\uD574 \uC8FC\uC138\uC694.\u2019"
      rationale: "\uB9C9\uC5F0\uD55C \u2018\uB3C4\uC640\uC8FC\uC138\uC694\u2019\uBCF4\uB2E4
        \uC704\uCE58, \uD604\uC7AC \uC704\uD5D8, \uD544\uC694\uD55C \uC5ED\uD560\uC744
        \uC804\uB2EC\uD55C\uB2E4."
    - action: 4
      label: "\uAD00\uB9AC\uC790\uC5D0\uAC8C \uC989\uC2DC \uD604\uC7A5 \uC9C0\uC6D0\uC744
        \uC694\uCCAD\uD55C\uB2E4"
      operationalScript: "\u20184\uD559\uB144 2\uBC18 \uC704\uAE30\uC0C1\uD669\uC785\uB2C8\uB2E4.
        \uD559\uC0DD\xB7\uAD50\uC0AC \uC548\uC804 \uD655\uC778\uACFC \uD604\uC7A5
        \uC778\uACC4\uAC00 \uD544\uC694\uD569\uB2C8\uB2E4.\u2019"
      rationale: "\uD559\uAD50 \uC5ED\uD560 \uCCB4\uACC4\uC0C1 \uAD00\uB9AC\uC790
        \uAC1C\uC785\uC774 \uD544\uC694\uD55C \uC218\uC900\uC778\uC9C0 \uD310\uB2E8\uD55C\uB2E4."
  - beatId: 04.handoff
    phase: 3
    title: "\uB3C4\uCC29 \uD655\uC778\uACFC \uC5ED\uD560 \uC778\uACC4"
    situation: "\uC9C0\uC6D0 \uC694\uCCAD\uC744 \uBC1B\uC740 \uB3D9\uB8CC \uAD50\uC0AC\uAC00
      \uAD50\uC2E4 \uBB38 \uC55E\uC5D0 \uB3C4\uCC29\uD55C\uB2E4."
    privateTeacherPrompt: "\uB3C4\uCC29\uD588\uB2E4\uACE0 \uAC00\uC815\uD558\uC9C0
      \uB9D0\uACE0 \uC0C1\uB300\uAC00 \uC2E4\uC81C\uB85C \uC5ED\uD560\uC744 \uC778\uC218\uD588\uB294\uC9C0
      \uD655\uC778\uD558\uC138\uC694."
    observableSignals: "\uB3D9\uB8CC\uB294 \uC0C1\uD669\uC744 \uD30C\uC545\uD558\uB824\uACE0
      \uAD50\uC0AC\uC640 \uD559\uC0DD\uC744 \uBC88\uAC08\uC544 \uBCF8\uB2E4."
    facilitatorNote: "\uC778\uACC4\uC5D0\uB294 \uAD00\uCC30 \uC0AC\uC2E4, \uD604\uC7AC
      \uC704\uD5D8, \uC774\uBBF8 \uC2E4\uC2DC\uD55C \uC870\uCE58, \uB2E4\uC74C \uC5ED\uD560\uC774
      \uD3EC\uD568\uB418\uC5B4\uC57C \uD55C\uB2E4."
    debriefPrompt: "\uC778\uACC4\uD560 \uB54C \uC0AC\uC2E4\uACFC \uD574\uC11D\uC744
      \uC5B4\uB5BB\uAC8C \uAD6C\uBD84\uD588\uB294\uAC00?"
    completionAction: 6
    options:
    - action: 5
      label: "\uC9C0\uC6D0\uC778\uB825\uC758 \uB3C4\uCC29\uACFC \uC758\uC0AC\uC18C\uD1B5
        \uAC00\uB2A5 \uC0C1\uD0DC\uB97C \uD655\uC778\uD55C\uB2E4"
      operationalScript: "\uB208\uC744 \uB9DE\uCD94\uACE0 \uC774\uB984\uC744 \uBD80\uB978
        \uB4A4 \uC5ED\uD560\uC744 \uC804\uB2EC\uD560 \uC900\uBE44\uAC00 \uB418\uC5C8\uB294\uC9C0
        \uD655\uC778\uD55C\uB2E4."
      rationale: "\uC694\uCCAD \uC804\uC1A1\uACFC \uC2E4\uC81C \uC9C0\uC6D0 \uB3C4\uCC29\uC740
        \uB2E4\uB978 \uC0AC\uAC74\uC774\uB2E4."
    - action: 6
      label: "\uAD00\uCC30 \uC0AC\uC2E4\uACFC \uB2E4\uC74C \uC5ED\uD560\uC744 \uC9E7\uAC8C
        \uC778\uACC4\uD55C\uB2E4"
      operationalScript: "\u2018\uD544\uD1B5\uC744 \uBC14\uB2E5 \uCABD\uC73C\uB85C
        \uD55C \uBC88 \uB358\uC84C\uACE0 \uB2E4\uCE5C \uD559\uC0DD\uC740 \uC5C6\uC2B5\uB2C8\uB2E4.
        \uC55E\uC904 \uC774\uB3D9\uC744 \uBD80\uD0C1\uB4DC\uB9AC\uACE0, \uC800\uB294
        \uD559\uC0DD\uACFC \uAC70\uB9AC\uB97C \uB450\uACE0 \uB300\uD654\uD558\uACA0\uC2B5\uB2C8\uB2E4.\u2019"
      rationale: "\uACFC\uC7A5\uC774\uB098 \uC9C4\uB2E8 \uC5C6\uC774 \uC548\uC804\uC5D0
        \uD544\uC694\uD55C \uC815\uBCF4\uB9CC \uC804\uB2EC\uD55C\uB2E4."
  - beatId: 05.low-stimulus
    phase: 3
    title: "\uD300\uC774 \uD655\uBCF4\uB41C \uC0C1\uD0DC\uC5D0\uC11C \uD559\uC0DD\uC5D0\uAC8C
      \uC7AC\uC811\uCD09"
    situation: "\uC8FC\uBCC0 \uD559\uC0DD\uC774 \uC774\uB3D9\uD588\uACE0 \uB3D9\uB8CC\uAC00
      \uD559\uAE09\uC744 \uB9E1\uC558\uB2E4. \uCD08\uC810\uD559\uC0DD\uC740 \uC5EC\uC804\uD788
      \uD070 \uC228\uC744 \uC26C\uC9C0\uB9CC \uC190\uC5D0 \uB4E0 \uBB3C\uAC74\uC740
      \uC5C6\uB2E4."
    privateTeacherPrompt: "\uC9C0\uAE08 \uD559\uC0DD\uC5D0\uAC8C \uD544\uC694\uD55C
      \uB9D0\uC740 \uC124\uBA85, \uCC98\uBC8C, \uC9C8\uBB38 \uC911 \uBB34\uC5C7\uC778\uAC00?"
    observableSignals: "\uD559\uC0DD\uC758 \uBAA9\uC18C\uB9AC\uB294 \uB0AE\uC544\uC84C\uC9C0\uB9CC
      \uC2DC\uC120\uC744 \uD53C\uD558\uACE0 \uCD9C\uAD6C \uBC29\uD5A5\uC744 \uD655\uC778\uD55C\uB2E4."
    facilitatorNote: "\uC548\uC804\uB9DD\uC774 \uD655\uBCF4\uB41C \uD6C4 \uC9E7\uC740
      \uC778\uC815\uACFC \uC120\uD0DD\uAD8C\uC744 \uC81C\uACF5\uD558\uB418 \uC0AC\uAC74
      \uC870\uC0AC\uB294 \uC548\uC815 \uC774\uD6C4\uB85C \uBBF8\uB8EC\uB2E4."
    debriefPrompt: "\uB0B4 \uBC1C\uD654\uAC00 \uD559\uC0DD\uC5D0\uAC8C \uCC98\uB9AC\uD560
      \uC815\uBCF4\uB7C9\uC744 \uC904\uC600\uB294\uAC00?"
    completionAction: 1
    options:
    - action: 1
      label: "\uC9E7\uAC8C \uAC10\uC815\uC744 \uD655\uC778\uD558\uACE0 \uC548\uC804\uD55C
        \uC120\uD0DD\uC744 \uC81C\uC2DC\uD55C\uB2E4"
      operationalScript: "\u2018\uB9CE\uC774 \uB2F5\uB2F5\uD574 \uBCF4\uC778\uB2E4.
        \uC5EC\uAE30\uC11C \uC870\uC6A9\uD788 \uAE30\uB2E4\uB9B4\uC9C0, \uC0C1\uB2F4\uC2E4
        \uC55E\uAE4C\uC9C0 \uD568\uAED8 \uAC08\uC9C0 \uC120\uD0DD\uD574\uB3C4 \uB3FC.\u2019"
      rationale: "\uB0AE\uC740 \uC790\uADF9, \uC120\uD0DD\uAD8C, \uC548\uC804\uD55C
        \uB3D9\uD589\uC744 \uACB0\uD569\uD55C\uB2E4."
  - beatId: 06.documentation
    phase: 4
    title: "\uC0AC\uC2E4 \uC911\uC2EC \uC0AC\uAC74 \uAE30\uB85D"
    situation: "\uD559\uC0DD\uACFC \uD559\uAE09\uC758 \uC989\uAC01\uC801 \uC704\uD5D8\uC774
      \uB0AE\uC544\uC9C0\uACE0 \uC9C0\uC6D0\uC778\uB825\uC5D0\uAC8C \uD604\uC7A5\uC774
      \uC778\uACC4\uB418\uC5C8\uB2E4."
    privateTeacherPrompt: "\uAE30\uB85D\uC5D0\uC11C \uC9C1\uC811 \uBCF8 \uC0AC\uC2E4,
      \uD559\uC0DD\uC774 \uD55C \uB9D0, \uAD50\uC0AC\uC758 \uD574\uC11D\uC744 \uAD6C\uBD84\uD558\uC138\uC694."
    observableSignals: "\uD604\uC7A5 \uC2DC\uAC04, \uC704\uCE58, \uBB3C\uAC74\uC758
      \uBC29\uD5A5, \uC8FC\uBCC0 \uD559\uC0DD \uC704\uCE58\uC640 \uC2E4\uC2DC\uD55C
      \uC870\uCE58\uB97C \uD655\uC778\uD560 \uC218 \uC788\uB2E4."
    facilitatorNote: "\u2018\uD3ED\uB825\uC801 \uC131\uD5A5\u2019 \uAC19\uC740 \uB099\uC778
      \uB300\uC2E0 \uAD00\uCC30 \uAC00\uB2A5\uD55C \uD589\uB3D9\uACFC \uC2DC\uAC04\uC21C
      \uC870\uCE58\uB97C \uAE30\uB85D\uD55C\uB2E4."
    debriefPrompt: "\uB0B4 \uAE30\uB85D\uC5D0 \uC9C4\uB2E8\xB7\uBE44\uB09C\xB7\uCD94\uCE21
      \uD45C\uD604\uC774 \uC11E\uC774\uC9C0 \uC54A\uC558\uB294\uAC00?"
    completionAction: 7
    options:
    - action: 7
      label: "\uC2DC\uAC04\xB7\uAD00\uCC30\xB7\uC870\uCE58\xB7\uC778\uACC4\uB97C
        \uC21C\uC11C\uB300\uB85C \uAE30\uB85D\uD55C\uB2E4"
      operationalScript: "\u201811:18 \uD559\uC0DD\uC774 \uD544\uD1B5\uC744 \uAD50\uC2E4
        \uC55E \uBC14\uB2E5 \uBC29\uD5A5\uC73C\uB85C \uB358\uC9D0. \uC811\uCD09\xB7\uBD80\uC0C1
        \uC5C6\uC74C. 11:19 \uC55E\uC904 \uD559\uC0DD \uC774\uB3D9. 11:20 \uB3D9\uB8CC
        \uAD50\uC0AC \uB3C4\uCC29 \uBC0F \uD559\uAE09 \uC778\uACC4.\u2019"
      rationale: "\uC0AC\uD6C4 \uD611\uC5C5\uACFC \uBCF4\uD638\uC790 \uC18C\uD1B5\uC5D0
        \uC0AC\uC6A9\uD560 \uC218 \uC788\uB294 \uAC80\uC99D \uAC00\uB2A5\uD55C \uAE30\uB85D\uC744
        \uB0A8\uAE34\uB2E4."
  - beatId: 07.recovery
    phase: 5
    title: "\uAD50\uC0AC \uD68C\uBCF5\uACFC \uB2E4\uC74C \uC9C0\uC6D0 \uACC4\uD68D"
    situation: "\uC0AC\uAC74\uC740 \uC815\uB9AC\uB418\uC5C8\uC9C0\uB9CC \uAD50\uC0AC\uB294
      \uC190\uC774 \uB5A8\uB9AC\uACE0, \uD559\uC0DD\uC758 \uB9D0\uC774 \uBC18\uBCF5\uD574\uC11C
      \uB5A0\uC624\uB978\uB2E4."
    privateTeacherPrompt: "\uC774 \uBC18\uC751\uC744 \uAC1C\uC778\uC758 \uC2E4\uD328\uB85C
      \uD310\uB2E8\uD558\uC9C0 \uB9D0\uACE0 \uD544\uC694\uD55C \uD68C\uBCF5\uACFC
      \uC5C5\uBB34 \uC9C0\uC6D0\uC744 \uC120\uD0DD\uD558\uC138\uC694."
    observableSignals: "\uAE34\uC7A5\uC774 \uB0A8\uC544 \uC788\uACE0 \uB2E4\uC74C
      \uC218\uC5C5 \uC900\uBE44\uC5D0 \uC9D1\uC911\uD558\uAE30 \uC5B4\uB835\uB2E4."
    facilitatorNote: "\uD68C\uBCF5 \uC694\uCCAD\uC740 \uD3C9\uAC00 \uAC10\uC810 \uC694\uC18C\uAC00
      \uC544\uB2C8\uB2E4. \uB3D9\uB8CC \uB514\uBE0C\uB9AC\uD551, \uC0C1\uB2F4, \uC77C\uC815
      \uC870\uC815\uC744 \uAD6C\uCCB4\uD654\uD55C\uB2E4."
    debriefPrompt: "\uB0B4\uAC00 \uD1B5\uC81C\uD560 \uC218 \uC788\uC5C8\uB358 \uAC83\uACFC
      \uC870\uC9C1\uC758 \uC9C0\uC6D0\uC774 \uD544\uC694\uD588\uB358 \uAC83\uC740
      \uAC01\uAC01 \uBB34\uC5C7\uC778\uAC00?"
    completionAction: 8
    options:
    - action: 8
      label: "\uB3D9\uB8CC \uB514\uBE0C\uB9AC\uD551\uACFC \uD544\uC694\uD55C \uD68C\uBCF5
        \uC9C0\uC6D0\uC744 \uC694\uCCAD\uD55C\uB2E4"
      operationalScript: "\u2018\uC624\uB298 \uC0AC\uAC74\uC744 \uC0AC\uC2E4 \uC911\uC2EC\uC73C\uB85C
        \uD568\uAED8 \uAC80\uD1A0\uD558\uACE0 \uC2F6\uC2B5\uB2C8\uB2E4. \uB2E4\uC74C
        \uC218\uC5C5 \uC804 \uC7A0\uC2DC \uC548\uC815\uD560 \uC2DC\uAC04\uACFC \uD6C4\uC18D
        \uC5ED\uD560 \uD655\uC778\uC774 \uD544\uC694\uD569\uB2C8\uB2E4.\u2019"
      rationale: "\uAC1C\uC778 \uCC45\uC784\uC73C\uB85C\uB9CC \uB3CC\uB9AC\uC9C0
        \uC54A\uACE0 \uD68C\uBCF5\uACFC \uC7AC\uBC1C \uBC29\uC9C0\uB97C \uC870\uC9C1\uC801
        \uD589\uB3D9\uC73C\uB85C \uC5F0\uACB0\uD55C\uB2E4."
