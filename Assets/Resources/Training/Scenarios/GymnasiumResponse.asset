      title: "\uBB34\uB300 \uC7AC\uB3C4\uC804"
      studentLine: "\u2026\uD55C \uC904\uB9CC \uD558\uB294 \uAC70\uBA74, \uD574 \uBCFC\uAC8C\uC694."
      observation: "\uCEE4\uD2BC \uB4A4\uC5D0\uC11C \uBB34\uB300\uB97C \uC0B4\uD53C\uBA70 \uB300\uBCF8\uC744 \uD3C5\uB2C8\uB2E4."
      entryGesture: 10
      gestureIntensity: 0.45
      options:
      - label: "\uD55C \uC904 \uC218\uD589\uC744 \uAD6C\uC870\uD654\uD558\uACE0 \uD1F4\uC7A5 \uACBD\uB85C\uB97C \uC900\uB2E4"
        spokenResponse: "\uC88B\uC544, \uCCAB \uC904\uB9CC. \uB9C8\uC774\uD06C\uB294 \uB0B4\uAC00 \uB4E4\uC5B4 \uC904\uAC8C. \uB05D\uB098\uBA74 \uBC14\uB85C \uB0B4 \uC606\uC73C\uB85C \uC624\uBA74 \uB3FC."
        quality: 3
        rationale: "\uC131\uACF5 \uAE30\uC900 \uCD95\uC18C\uC640 \uD1F4\uC7A5 \uBCF4\uC7A5: \uC218\uD589 \uBD80\uB2F4\uACFC \uD1F4\uB85C\uB97C \uD568\uAED8 \uC124\uACC4\uD574 \uC7AC\uB3C4\uC804\uC774 \uC548\uC804\uD558\uB2E4\uB294 \uACBD\uD5D8\uC744 \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC804\uCCB4 \uBC15\uC218\uB97C \uC720\uB3C4\uD55C\uB2E4"
        spokenResponse: "\uC6B0\uC640, \uC11C\uC724\uC774 \uC6A9\uAE30 \uB0C8\uB2E4! \uB2E4\uB4E4 \uBC15\uC218!"
        quality: 2
        rationale: "\uC120\uC758\uC758 \uCD95\uD558\uC9C0\uB9CC \uC804\uC6D0\uC758 \uC8FC\uBAA9\uC744 \uB2E4\uC2DC \uBAA8\uC544 \uB2E4\uC74C \uB3C4\uC804\uC758 \uBD80\uB2F4\uC744 \uD0A4\uC6B8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uB05D\uAE4C\uC9C0 \uD574 \uBCF4\uC790\uACE0 \uD55C\uB2E4"
        spokenResponse: "\uC774\uC655 \uD558\uB294 \uAC70 \uB05D\uAE4C\uC9C0 \uB2E4 \uD574 \uBCF4\uC790."
        quality: 1
        rationale: "\uD569\uC758\uB97C \uB118\uC5B4\uC120 \uC989\uC11D \uD655\uB300\uB294 \uC57D\uC18D \uC704\uBC18\uC73C\uB85C \uACBD\uD5D8\uB418\uC5B4 \uC2E0\uB8B0\uB97C \uAE4E\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
