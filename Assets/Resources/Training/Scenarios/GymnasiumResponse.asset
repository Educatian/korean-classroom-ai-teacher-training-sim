  m_Name: GymnasiumResponse
  m_EditorClassIdentifier: AdieLab.TeacherTraining::AdieLab.TeacherTraining.TrainingScenarioAsset
  scenarioId: GymnasiumResponse
  displayName: "\uAC15\uB2F9 \uD559\uC608\uD68C \uB9AC\uD5C8\uC124 \uC704\uAE30 \uB300\uC751"
  sceneId: 5
  researchNotes: "\uBB34\uB300 \uBD88\uC548\u00B7\uAC10\uAC01 \uACFC\uBD80\uD558\u00B7\uB2E8\uCCB4 \uC774\uD0C8 \uD6C8\uB828. \uBE44\uD2B8\u00B7\uC120\uD0DD\uC9C0\u00B7\uC5ED\uB7C9 \uBAA9\uD45C\uB294 Inspector\uC5D0\uC11C \uC218\uC815\uD569\uB2C8\uB2E4."
  beats:
  - scenarioId: Gymnasium.StageFear.01
    trigger: "\uBB34\uB300 \uBD88\uC548"
    stage: 0
    studentPersona: {fileID: 11400000, guid: d7a6f52259749ea48a58e43483faf0a7, type: 2}
    crisisType: 4
    teacherGoals: 0200000003000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uBB34\uB300 \uBD88\uC548"
      studentLine: "\uBB34\uB300\uC5D0 \uC11C\uBA74 \uB2E4 \uAE4C\uBA39\uC744 \uAC83 \uAC19\uC544\uC694. \uBC30\uAC00 \uC544\uD508 \uAC83 \uAC19\uC544\uC694."
      observation: "\uBB34\uB300 \uC606 \uACC4\uB2E8\uC5D0\uC11C \uB300\uBCF8\uC744 \uAD6C\uAE30\uBA70 \uD638\uD761\uC774 \uC595\uC544\uC9D1\uB2C8\uB2E4."
      entryGesture: 2
      gestureIntensity: 0.55
      options:
      - label: "\uBD88\uC548\uC744 \uC815\uC0C1\uD654\uD558\uACE0 \uC218\uD589 \uBC29\uC2DD\uC744 \uACE0\uB974\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uADF8 \uB9C8\uC74C \uC790\uC5F0\uC2A4\uB7EC\uC6B4 \uAC70\uC57C. \uC624\uB298\uC740 \uBB34\uB300 \uC704\uC5D0\uC11C \uD55C \uC904\uB9CC \uD574 \uBCFC\uC9C0, \uBB34\uB300 \uC544\uB798\uC5D0\uC11C \uD574 \uBCFC\uC9C0 \uACE8\uB77C \uBCFC\uB798?"
        quality: 3
        rationale: "\uBD88\uC548 \uC815\uC0C1\uD654\uC640 \uC218\uD589 \uC870\uC808\uAD8C: \uB5A8\uB9BC\uC744 \uBB38\uC81C\uB85C \uB9CC\uB4E4\uC9C0 \uC54A\uACE0 \uC218\uD589 \uAC15\uB3C4\uB97C \uD559\uC0DD\uC774 \uACE0\uB974\uAC8C \uD574 \uD68C\uD53C \uB300\uC2E0 \uC811\uADFC\uC744 \uD0DD\uD558\uAC8C \uD569\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC790\uC2E0\uAC10\uC744 \uAC00\uC9C0\uB77C\uACE0 \uACA9\uB824\uD55C\uB2E4"
        spokenResponse: "\uC5F0\uC2B5 \uB9CE\uC774 \uD588\uC796\uC544. \uC790\uC2E0\uAC10\uC744 \uAC00\uC838!"
        quality: 1
        rationale: "\uACA9\uB824\uC9C0\uB9CC \uBD88\uC548\uC758 \uC2E0\uCCB4 \uC2E0\uD638\uB97C \uBB34\uC2DC\uD55C \uCC44 \uACB0\uACFC\uB9CC \uC694\uAD6C\uD558\uB294 \uB9D0\uB85C \uB4E4\uB9AC\uAE30 \uC27D\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uCC28\uB840\uB77C\uACE0 \uC7AC\uCD09\uD55C\uB2E4"
        spokenResponse: "\uB124 \uCC28\uB840 \uB2E4 \uB410\uC5B4. \uBE68\uB9AC \uC62C\uB77C\uAC00."
        quality: 0
        rationale: "\uC900\uBE44\uB418\uC9C0 \uC54A\uC740 \uB178\uCD9C \uAC15\uC694\uB294 \uBB34\uB300 \uC790\uCCB4\uB97C \uACF5\uD3EC \uC790\uADF9\uC73C\uB85C \uAC01\uC778\uC2DC\uD0B5\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: Gymnasium.NoiseOverload.02
    trigger: "\uC18C\uC74C \uACFC\uBD80\uD558"
    stage: 1
    studentPersona: {fileID: 11400000, guid: d7a6f52259749ea48a58e43483faf0a7, type: 2}
    crisisType: 0
    teacherGoals: 0100000004000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uC18C\uC74C \uACFC\uBD80\uD558"
      studentLine: "\uB108\uBB34 \uC2DC\uB044\uB7EC\uC6CC\uC694\u2026 \uBA38\uB9AC\uAC00 \uC544\uD30C\uC694."
      observation: "\uB9C8\uC774\uD06C \uC18C\uB9AC\uC640 \uBC15\uC218 \uC18C\uB9AC\uC5D0 \uADC0\uB97C \uB9C9\uACE0 \uBAB8\uC744 \uC6C5\uD06C\uB9BD\uB2C8\uB2E4. \uAC15\uB2F9\uC758 \uC6B8\uB9BC\uC774 \uC790\uADF9\uC744 \uD0A4\uC6C1\uB2C8\uB2E4."
      entryGesture: 7
      gestureIntensity: 0.7
      options:
      - label: "\uC790\uADF9\uC744 \uB0AE\uCD9C \uACF5\uAC04\uC73C\uB85C \uD568\uAED8 \uC774\uB3D9\uD55C\uB2E4"
        spokenResponse: "\uADC0\uAC00 \uB9CE\uC774 \uD798\uB4E4\uC5C8\uAD6C\uB098. \uC800 \uB4A4 \uC870\uC6A9\uD55C \uCF54\uB108\uB85C \uAC00\uC790. \uB9AC\uD5C8\uC124 \uC18C\uB9AC\uB3C4 \uC904\uC5EC \uB2EC\uB77C\uACE0 \uD560\uAC8C."
        quality: 3
        rationale: "\uAC10\uAC01 \uBD80\uB2F4 \uC778\uC815\uACFC \uD658\uACBD \uC870\uC815: \uC544\uC774\uB97C \uC62E\uAE30\uB294 \uAC83\uC5D0\uC11C \uBA48\uCD94\uC9C0 \uC54A\uACE0 \uC18C\uC74C\uC6D0 \uC790\uCCB4\uB97C \uC870\uC815\uD574 \uC7AC\uCC38\uC5EC \uC870\uAC74\uC744 \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC870\uAE08\uB9CC \uCC38\uC73C\uB77C\uACE0 \uD55C\uB2E4"
        spokenResponse: "\uAE08\uBC29 \uB05D\uB098. \uC870\uAE08\uB9CC \uCC38\uC790."
        quality: 1
        rationale: "\uC778\uB0B4 \uC694\uAD6C\uB294 \uAC10\uAC01 \uACFC\uBD80\uD558\uB97C \uC758\uC9C0 \uBB38\uC81C\uB85C \uCE58\uD658\uD569\uB2C8\uB2E4. \uBD80\uB2F4\uC740 \uB204\uC801\uB418\uC5B4 \uB354 \uD06C\uAC8C \uD130\uC9D1\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC720\uB09C\uC774\uB77C\uACE0 \uC9C0\uC801\uD55C\uB2E4"
        spokenResponse: "\uB2E4\uB4E4 \uCC38\uB294\uB370 \uC65C \uB108\uB9CC \uC720\uB09C\uC774\uC57C."
        quality: 0
        rationale: "\uAC10\uAC01 \uBC18\uC751\uC758 \uACF5\uAC1C \uBE44\uB09C\uC740 \uC218\uCE58\uC2EC\uC744 \uB354\uD558\uACE0 \uB3C4\uC6C0 \uC694\uCCAD \uACBD\uB85C\uB97C \uB2EB\uC2B5\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: Gymnasium.LineScuffle.03
    trigger: "\uC904\uC11C\uAE30 \uBAB8\uC2F8\uC6C0"
    stage: 2
    studentPersona: {fileID: 11400000, guid: d7a6f52259749ea48a58e43483faf0a7, type: 2}
    crisisType: 3
    teacherGoals: 0000000004000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uC904\uC11C\uAE30 \uBAB8\uC2F8\uC6C0"
      studentLine: "\uC7E4\uAC00 \uC0C8\uCE58\uAE30\uD588\uC5B4\uC694! \uC6D0\uB798 \uC81C \uC790\uB9AC\uB77C\uACE0\uC694!"
      observation: "\uC785\uC7A5 \uC904\uC5D0\uC11C \uBC00\uCE58\uB77D\uC774 \uC2DC\uC791\uB418\uACE0 \uC8FC\uBCC0 \uC544\uC774\uB4E4\uC774 \uBAB0\uB824\uB4ED\uB2C8\uB2E4."
      entryGesture: 4
      gestureIntensity: 0.75
      options:
      - label: "\uC904 \uBC16\uC73C\uB85C \uBD84\uB9AC\uD558\uACE0 \uBC00\uCE68\uBD80\uD130 \uBA48\uCD98\uB2E4"
        spokenResponse: "\uB458 \uB2E4 \uC904 \uBC16\uC73C\uB85C \uC7A0\uAE50 \uB098\uC640. \uC790\uB9AC\uB294 \uB0B4\uAC00 \uD655\uC778\uD560\uAC8C. \uBBF8\uB294 \uAC74 \uC704\uD5D8\uD574\uC11C \uBA3C\uC800 \uBA48\uCDB0\uC57C \uD574."
        quality: 3
        rationale: "\uBD84\uB9AC\uC640 \uC548\uC804 \uC6B0\uC120: \uC2DC\uBE44 \uD310\uC815\uBCF4\uB2E4 \uC2E0\uCCB4 \uC811\uCD09 \uC911\uB2E8\uC744 \uBA3C\uC800 \uC138\uC6B0\uACE0 \uD655\uC778 \uCC45\uC784\uC744 \uAD50\uC0AC\uAC00 \uAC00\uC838\uAC00 \uCCB4\uBA74 \uB2E4\uD23C\uC744 \uB05D\uB0C5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uB458 \uB2E4 \uB9E8 \uB4A4\uB85C \uBCF4\uB0B8\uB2E4"
        spokenResponse: "\uB458 \uB2E4 \uB9E8 \uB4A4\uB85C \uAC00!"
        quality: 0
        rationale: "\uC77C\uAD04 \uCC98\uBC8C\uC740 \uC5B5\uC6B8\uD568\uC744 \uACF5\uC815\uC131 \uBD88\uC2E0\uC73C\uB85C \uBC14\uAFB8\uACE0 \uB2E4\uC74C \uC904\uC11C\uAE30\uC5D0\uC11C \uC7AC\uBC1C\uD569\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
      - label: "\uC591\uBCF4\uB97C \uC885\uC6A9\uD55C\uB2E4"
        spokenResponse: "\uB124\uAC00 \uD615\uB2F5\uAC8C \uC591\uBCF4\uD574."
        quality: 1
        rationale: "\uC5ED\uD560 \uC555\uBC15\uD615 \uC591\uBCF4 \uC694\uAD6C\uB294 \uD55C\uCABD\uC758 \uC5B5\uC6B8\uD568\uC744 \uB355\uBAA9\uC758 \uC774\uB984\uC73C\uB85C \uB20C\uB7EC \uB458 \uBFD0\uC785\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
  - scenarioId: Gymnasium.DefeatRage.04
    trigger: "\uACBD\uAE30 \uD328\uBC30 \uBD84\uB178"
    stage: 3
    studentPersona: {fileID: 11400000, guid: d7a6f52259749ea48a58e43483faf0a7, type: 2}
    crisisType: 3
    teacherGoals: 0200000000000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uACBD\uAE30 \uD328\uBC30 \uBD84\uB178"
      studentLine: "\uC6B0\uB9AC \uD300\uC774 \uC9C4 \uAC74 \uB2E4 \uC7E4 \uB54C\uBB38\uC774\uC5D0\uC694!"
      observation: "\uACC4\uC8FC \uBC14\uD1B5\uC744 \uBC14\uB2E5\uC5D0 \uB358\uC9C0\uACE0 \uD300\uC6D0\uC744 \uB178\uB824\uBD05\uB2C8\uB2E4."
      entryGesture: 5
      gestureIntensity: 0.75
      options:
      - label: "\uBD84\uD568\uC740 \uC778\uC815\uD558\uB418 \uBE44\uB09C\uC5D0\uC11C \uBD84\uB9AC\uD574 \uB370\uB9AC\uACE0 \uB098\uC628\uB2E4"
        spokenResponse: "\uC9C0\uBA74 \uC18D\uC0C1\uD558\uC9C0. \uADF8 \uB9C8\uC74C\uC740 \uB9DE\uC544. \uADFC\uB370 \uC800 \uB9D0\uC740 \uCE5C\uAD6C \uB9C8\uC74C\uC744 \uB2E4\uCE58\uAC8C \uD574. \uC7A0\uAE50 \uB098\uB791 \uBB3C \uB9C8\uC2DC\uB7EC \uAC00\uC790."
        quality: 3
        rationale: "\uAC10\uC815 \uD0C0\uB2F9\uD654\uC640 \uD589\uB3D9 \uACBD\uACC4: \uBD84\uB178 \uC790\uCCB4\uB294 \uC778\uC815\uD558\uACE0 \uBE44\uB09C \uD589\uB3D9\uB9CC \uACBD\uACC4 \uC9C0\uC73C\uBA70 \uC7A5\uBA74\uC5D0\uC11C \uBD84\uB9AC\uD574 \uC9C4\uC815 \uC2DC\uAC04\uC744 \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC2B9\uD328\uC758 \uC758\uBBF8\uB97C \uAC00\uB974\uCE5C\uB2E4"
        spokenResponse: "\uAC8C\uC784\uC774\uC796\uC544. \uC774\uAE38 \uB54C\uB3C4 \uC788\uACE0 \uC9C8 \uB54C\uB3C4 \uC788\uB294 \uAC70\uC57C."
        quality: 1
        rationale: "\uAD50\uD6C8\uC774 \uD2C0\uB9B0 \uAC83\uC740 \uC544\uB2C8\uB098 \uACA9\uC559 \uC0C1\uD0DC\uC5D0\uC11C\uB294 \uAC10\uC815\uC744 \uAC74\uB108\uB6F4 \uC124\uAD50\uB85C \uB4E4\uB9BD\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uCD9C\uC804 \uBC30\uC81C\uB97C \uACBD\uACE0\uD55C\uB2E4"
        spokenResponse: "\uADF8\uB807\uAC8C \uB9D0\uD558\uBA74 \uB2E4\uC74C \uACBD\uAE30 \uBABB \uB6F0\uAC8C \uD55C\uB2E4."
        quality: 0
        rationale: "\uCC98\uBC8C \uACBD\uACE0\uB294 \uBD84\uB178\uC5D0 \uC0C1\uC2E4 \uC704\uD611\uC744 \uB354\uD574 \uD3ED\uBC1C \uC9C1\uC804\uC758 \uD559\uC0DD\uC744 \uB354 \uBAB0\uC544\uBD99\uC785\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: Gymnasium.WalkOut.05
    trigger: "\uB2E8\uCCB4 \uD65C\uB3D9 \uC774\uD0C8"
    stage: 3
    studentPersona: {fileID: 11400000, guid: d7a6f52259749ea48a58e43483faf0a7, type: 2}
    crisisType: 1
    teacherGoals: 0300000005000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uB2E8\uCCB4 \uD65C\uB3D9 \uC774\uD0C8"
      studentLine: "\uC800 \uADF8\uB0E5 \uC9D1\uC5D0 \uAC08\uB798\uC694. \uC5EC\uAE30 \uC788\uAE30 \uC2EB\uC5B4\uC694."
      observation: "\uB300\uC5F4\uC5D0\uC11C \uBE60\uC838\uB098\uC640 \uAC15\uB2F9 \uCD9C\uC785\uBB38 \uCABD\uC73C\uB85C \uAC78\uC5B4\uAC11\uB2C8\uB2E4."
      entryGesture: 3
      gestureIntensity: 0.6
      options:
      - label: "\uBA38\uBB3C \uACF3\uC744 \uACE0\uB974\uAC8C \uD558\uACE0 \uC7AC\uC811\uCD09\uC744 \uC608\uACE0\uD55C\uB2E4"
        spokenResponse: "\uC9C0\uAE08\uC740 \uB098\uAC00\uACE0 \uC2F6\uAD6C\uB098. \uBB38 \uC55E \uBCA4\uCE58\uC5D0\uC11C \uB098\uB791 \uC788\uC744\uC9C0, \uB4A4\uCABD \uB9E4\uD2B8\uC5D0\uC11C \uC274\uC9C0 \uACE0\uB974\uC790. \uB2E4\uC74C \uC21C\uC11C \uC804\uC5D0 \uB2E4\uC2DC \uC774\uC57C\uAE30\uD558\uC790."
        quality: 3
        rationale: "\uC774\uD0C8 \uC695\uAD6C\uC758 \uAD6C\uC870\uD654: \uB5A0\uB098\uB824\uB294 \uD798\uC744 \uB9C9\uC9C0 \uC54A\uACE0 \uC548\uC804\uD55C \uC120\uD0DD\uC9C0\uB85C \uBC14\uAFB8\uBA70 \uBCF5\uADC0 \uC2DC\uC810\uC744 \uBBF8\uB9AC \uC57D\uC18D\uD569\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uBB34\uB2E8\uC774\uD0C8\uC774\uB77C\uACE0 \uACBD\uACE0\uD55C\uB2E4"
        spokenResponse: "\uC9C0\uAE08 \uB098\uAC00\uBA74 \uBB34\uB2E8\uC774\uD0C8\uC774\uC57C."
        quality: 0
        rationale: "\uADDC\uC815 \uC704\uD611\uC740 \uB0A8\uC744 \uC774\uC720\uAC00 \uC544\uB2C8\uB77C \uB3C4\uB9DD\uCE60 \uC774\uC720\uB97C \uD558\uB098 \uB354 \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
      - label: "\uC790\uB9AC\uB85C \uB3CC\uB824\uBCF4\uB0B4\uB824 \uD55C\uB2E4"
        spokenResponse: "\uC77C\uB2E8 \uC790\uB9AC\uB85C \uB3CC\uC544\uAC00\uC790, \uC751?"
        quality: 1
        rationale: "\uB2EC\uB798\uBA70 \uB418\uB3CC\uB9AC\uAE30\uB294 \uC774\uD0C8\uC758 \uC6D0\uC778\uC744 \uB4E3\uC9C0 \uC54A\uC740 \uCC44 \uB300\uC5F4 \uC720\uC9C0\uB9CC \uC6B0\uC120\uD558\uB294 \uB300\uC751\uC785\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
