  m_Name: SchoolyardResponse
  m_EditorClassIdentifier: AdieLab.TeacherTraining::AdieLab.TeacherTraining.TrainingScenarioAsset
  scenarioId: SchoolyardResponse
  displayName: "\uC6B4\uB3D9\uC7A5 \uC26C\uB294 \uC2DC\uAC04 \uC704\uAE30 \uB300\uC751"
  sceneId: 4
  researchNotes: "\uC26C\uB294 \uC2DC\uAC04 \uC57C\uC678 \uB610\uB798 \uAC08\uB4F1\u00B7\uC548\uC804 \uC704\uAE30 \uD6C8\uB828. \uBE44\uD2B8\u00B7\uC120\uD0DD\uC9C0\u00B7\uC5ED\uB7C9 \uBAA9\uD45C\uB294 Inspector\uC5D0\uC11C \uC218\uC815\uD569\uB2C8\uB2E4."
  beats:
  - scenarioId: Schoolyard.Exclusion.01
    trigger: "\uB180\uC774 \uBC30\uC81C"
    stage: 0
    studentPersona: {fileID: 11400000, guid: f4a8add639795e14b8aeb9ff20ec000b, type: 2}
    crisisType: 3
    teacherGoals: 0200000000000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uB180\uC774 \uBC30\uC81C"
      studentLine: "\uC800 \uC548 \uAEF4\uC900\uB300\uC694. \uB9E8\uB0A0 \uC800\uB9CC \uBE7C\uC694."
      observation: "\uD3B8 \uB098\uB204\uAE30\uAC00 \uB05D\uB09C \uB4A4 \uD63C\uC790 \uACE8\uB300 \uB4A4\uB85C \uBB3C\uB7EC\uB098 \uC2DC\uC120\uC744 \uD53C\uD569\uB2C8\uB2E4."
      entryGesture: 1
      gestureIntensity: 0.55
      options:
      - label: "\uAC10\uC815\uC744 \uC778\uC815\uD558\uACE0 \uCC38\uC5EC \uACBD\uB85C\uB97C \uD568\uAED8 \uC815\uD55C\uB2E4"
        spokenResponse: "\uC18D\uC0C1\uD588\uACA0\uB2E4. \uC120\uC0DD\uB2D8\uC774\uB791 \uC7A0\uAE50 \uBCF4\uACE0, \uB2E4\uC74C \uD310\uC5D0 \uC5B4\uB5BB\uAC8C \uB4E4\uC5B4\uAC08\uC9C0 \uAC19\uC774 \uC815\uD558\uC790."
        quality: 3
        rationale: "\uAC10\uC815 \uC778\uC815\uACFC \uC7AC\uC9C4\uC785 \uC124\uACC4: \uBC30\uC81C\uC758 \uC0C1\uCC98\uB97C \uBA3C\uC800 \uD655\uC778\uD558\uACE0 \uB2E4\uC74C \uCC38\uC5EC \uBC29\uBC95\uC744 \uD568\uAED8 \uC815\uD574 \uACF5\uAC1C\uC801 \uAC1C\uC785 \uC5C6\uC774 \uC874\uC5C4\uC744 \uC9C0\uD0B5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uCE5C\uAD6C\uB4E4\uC5D0\uAC8C \uB07C\uC6CC \uC8FC\uB77C\uACE0 \uB9D0\uD55C\uB2E4"
        spokenResponse: "\uC598\uB4E4\uC544, \uC9C0\uD638\uB3C4 \uAEF4 \uC918."
        quality: 1
        rationale: "\uC120\uC758\uC758 \uAC1C\uC785\uC774\uC9C0\uB9CC \uAD50\uC0AC\uAC00 \uC5B5\uC9C0\uB85C \uB07C\uC6CC \uB123\uC740 \uC544\uC774\uAC00 \uB418\uC5B4 \uCCB4\uBA74\uC774 \uC0C1\uD558\uACE0 \uB2E4\uC74C \uBC30\uC81C\uC758 \uBE4C\uBBF8\uAC00 \uB418\uAE30 \uC27D\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uB300\uC218\uB86D\uC9C0 \uC54A\uAC8C \uB118\uAE34\uB2E4"
        spokenResponse: "\uADF8\uB7F4 \uC218\uB3C4 \uC788\uC9C0. \uB2E4\uB978 \uB180\uC774 \uD558\uBA74 \uB418\uC796\uC544."
        quality: 0
        rationale: "\uBC30\uC81C \uACBD\uD5D8\uC758 \uCD95\uC18C\uB294 \uB3C4\uC6C0 \uC694\uCCAD\uC774 \uBB34\uC2DC\uB418\uC5C8\uB2E4\uB294 \uD559\uC2B5\uC744 \uB0A8\uAE41\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: Schoolyard.RuleDispute.02
    trigger: "\uADDC\uCE59 \uBD84\uC7C1 \uACA9\uD654"
    stage: 1
    studentPersona: {fileID: 11400000, guid: f4a8add639795e14b8aeb9ff20ec000b, type: 2}
    crisisType: 3
    teacherGoals: 0100000003000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uADDC\uCE59 \uBD84\uC7C1 \uACA9\uD654"
      studentLine: "\uBC18\uCE59\uC774\uC5C8\uB2E4\uACE0\uC694! \uC7E4\uB124\uAC00 \uAC70\uC9D3\uB9D0\uD558\uB294 \uAC70\uC608\uC694!"
      observation: "\uBAA9\uC18C\uB9AC\uAC00 \uCEE4\uC9C0\uACE0 \uC0C1\uB300 \uD300 \uCABD\uC73C\uB85C \uB2E4\uAC00\uC12D\uB2C8\uB2E4."
      entryGesture: 4
      gestureIntensity: 0.7
      options:
      - label: "\uACBD\uAE30\uB97C \uBA48\uCD94\uACE0 \uC591\uCABD\uC744 \uB098\uB220 \uB4E3\uB294\uB2E4"
        spokenResponse: "\uC7A0\uAE50 \uACBD\uAE30 \uBA48\uCD94\uC790. \uC591\uCABD \uC774\uC57C\uAE30 \uB2E4 \uB4E4\uC744\uAC8C. \uC9C0\uD638\uBD80\uD130 \uC774\uCABD\uC5D0\uC11C \uC870\uC6A9\uD788 \uB9D0\uD574 \uC918."
        quality: 3
        rationale: "\uC77C\uC2DC \uC815\uC9C0\uC640 \uBD84\uB9AC \uCCAD\uCDE8: \uD310\uC815\uC744 \uC11C\uB450\uB974\uC9C0 \uC54A\uACE0 \uBC1C\uD654 \uC21C\uC11C\uC640 \uC7A5\uC18C\uB97C \uAD6C\uC870\uD654\uD574 \uACA9\uC559\uC744 \uB0AE\uCDA5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC989\uC11D\uC5D0\uC11C \uD310\uC815\uD55C\uB2E4"
        spokenResponse: "\uB0B4\uAC00 \uBD24\uB294\uB370 \uBC18\uCE59 \uC544\uB2C8\uC57C. \uACC4\uC18D\uD574."
        quality: 0
        rationale: "\uD604\uC7A5 \uC989\uACB0 \uD310\uC815\uC740 \uD55C\uCABD\uC744 \uACF5\uAC1C\uC801\uC73C\uB85C \uAC70\uC9D3\uB9D0\uC7C1\uC774\uB85C \uB9CC\uB4E4\uC5B4 \uAC08\uB4F1\uC744 \uC2EC\uD654\uC2DC\uD0B5\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
      - label: "\uBB34\uD6A8\uB97C \uC120\uC5B8\uD558\uACE0 \uB2E4\uC2DC \uC2DC\uC791\uD558\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uADF8\uB7FC \uC774\uBC88 \uD310\uC740 \uBB34\uD6A8. \uB2E4\uC2DC \uC2DC\uC791\uD574."
        quality: 1
        rationale: "\uD45C\uBA74\uC801 \uC911\uB9BD\uC774\uC9C0\uB9CC \uC5B5\uC6B8\uD568\uC758 \uC6D0\uC778\uC774 \uD574\uC18C\uB418\uC9C0 \uC54A\uC544 \uB2E4\uC74C \uD310\uC5D0\uC11C \uC7AC\uC810\uD654\uB418\uAE30 \uC27D\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
  - scenarioId: Schoolyard.PhysicalBrink.03
    trigger: "\uBAB8\uC2F8\uC6C0 \uC9C1\uC804"
    stage: 2
    studentPersona: {fileID: 11400000, guid: f4a8add639795e14b8aeb9ff20ec000b, type: 2}
    crisisType: 3
    teacherGoals: 0400000000000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uBAB8\uC2F8\uC6C0 \uC9C1\uC804"
      studentLine: "\uBE44\uCF1C\uC694! \uC7E4 \uC9C4\uC9DC \uD55C \uB300 \uCE60 \uAC70\uC608\uC694!"
      observation: "\uC8FC\uBA39\uC744 \uC950\uACE0 \uC0C1\uB300\uC5D0\uAC8C \uBE60\uB974\uAC8C \uB2E4\uAC00\uC12D\uB2C8\uB2E4. \uC989\uC2DC \uAC1C\uC785\uC774 \uD544\uC694\uD55C \uC548\uC804 \uC0C1\uD669\uC785\uB2C8\uB2E4."
      entryGesture: 9
      gestureIntensity: 0.85
      options:
      - label: "\uC0AC\uC774\uC5D0 \uC11C\uC11C \uB450 \uD559\uC0DD\uC744 \uBD84\uB9AC\uD55C\uB2E4"
        spokenResponse: "\uC120\uC0DD\uB2D8\uC774 \uC5EC\uAE30 \uC788\uC744\uAC8C. \uC9C0\uD638\uB294 \uB098\uB791 \uC774\uCABD\uC73C\uB85C, \uB108\uB294 \uC800\uCABD \uBCA4\uCE58\uB85C. \uC9C0\uAE08\uC740 \uB5A8\uC5B4\uC9C0\uB294 \uAC8C \uBA3C\uC800\uC57C."
        quality: 3
        rationale: "\uBB3C\uB9AC\uC801 \uAC1C\uC785\uACFC \uBD84\uB9AC: \uC2E0\uCCB4 \uCDA9\uB3CC \uC9C1\uC804\uC5D0\uB294 \uC548\uC804 \uD655\uBCF4\uAC00 \uB300\uD654\uBCF4\uB2E4 \uBA3C\uC800\uC774\uBA70, \uC591\uCABD \uBAA8\uB450\uC5D0\uAC8C \uAC08 \uACF3\uC744 \uC8FC\uC5B4 \uCCB4\uBA74\uC744 \uC9C0\uD0B5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uCC98\uBC8C\uC744 \uACBD\uACE0\uD55C\uB2E4"
        spokenResponse: "\uD55C \uB300\uB77C\uB3C4 \uCE58\uBA74 \uBC14\uB85C \uAD50\uBB34\uC2E4 \uAC04\uB2E4!"
        quality: 0
        rationale: "\uC704\uD611\uC740 \uAC01\uC131 \uCD5C\uACE0\uC870\uC758 \uD559\uC0DD\uC5D0\uAC8C \uB3C4\uC804 \uACFC\uC81C\uAC00 \uB418\uAE30 \uC27D\uACE0, \uD589\uB3D9\uC744 \uBA48\uCD9C \uBB3C\uB9AC\uC801 \uC548\uC804\uC7A5\uCE58\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
      - label: "\uC0C1\uB300\uC5D0\uAC8C \uC0AC\uACFC\uB97C \uC2DC\uD0A8\uB2E4"
        spokenResponse: "\uC57C, \uB124\uAC00 \uBA3C\uC800 \uC0AC\uACFC\uD574."
        quality: 1
        rationale: "\uBD84\uB9AC \uC5C6\uB294 \uC989\uC11D \uC911\uC7AC\uB294 \uD3B8\uB4E4\uAE30\uB85C \uC77D\uD788\uACE0 \uB450 \uD559\uC0DD \uBAA8\uB450 \uCCAD\uC911 \uC55E\uC5D0 \uC138\uC6CC \uB461\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
  - scenarioId: Schoolyard.FallShame.04
    trigger: "\uB118\uC5B4\uC9D0\uACFC \uCC3D\uD53C"
    stage: 1
    studentPersona: {fileID: 11400000, guid: f4a8add639795e14b8aeb9ff20ec000b, type: 2}
    crisisType: 0
    teacherGoals: 0200000005000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uB118\uC5B4\uC9D0\uACFC \uCC3D\uD53C"
      studentLine: "\uC548 \uC544\uD30C\uC694! \uC800\uB9AC \uAC00\uC694! \uCCD0\uB2E4\uBCF4\uC9C0 \uB9C8\uC694!"
      observation: "\uD2B8\uB799\uC5D0\uC11C \uB118\uC5B4\uC9C4 \uB4A4 \uC6C3\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB9AC\uC790 \uBB34\uB98E\uC744 \uAC10\uC2F8\uACE0 \uB4F1\uC744 \uB3CC\uB9BD\uB2C8\uB2E4."
      entryGesture: 3
      gestureIntensity: 0.65
      options:
      - label: "\uC2DC\uC120\uC744 \uB3CC\uB9AC\uACE0 \uD68C\uBCF5 \uC7A5\uC18C\uB97C \uACE0\uB974\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uB2E4\uCE5C \uB370 \uBA3C\uC800 \uBCF4\uC790. \uADF8\uB298 \uBCA4\uCE58\uB85C \uAC08\uAE4C, \uBCF4\uAC74\uC2E4\uB85C \uAC08\uAE4C? \uCE5C\uAD6C\uB4E4\uC740 \uACBD\uAE30 \uACC4\uC18D\uD558\uACE0."
        quality: 3
        rationale: "\uC8FC\uBAA9 \uCC28\uB2E8\uACFC \uD68C\uBCF5 \uACBD\uB85C \uC120\uD0DD: \uAD6C\uACBD\uC744 \uD574\uC0B0\uC2DC\uD0A4\uACE0 \uD559\uC0DD\uC774 \uD68C\uBCF5 \uC7A5\uC18C\uB97C \uACE0\uB974\uAC8C \uD574 \uCC3D\uD53C\uC758 \uBB34\uAC8C\uB97C \uC904\uC785\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC529\uC529\uD558\uAC8C \uC77C\uC5B4\uB098\uB77C\uACE0 \uACA9\uB824\uD55C\uB2E4"
        spokenResponse: "\uAD1C\uCC2E\uC544, \uC529\uC529\uD558\uAC8C \uC77C\uC5B4\uB098\uC57C\uC9C0!"
        quality: 1
        rationale: "\uBE60\uB978 \uBCF5\uADC0 \uC555\uBC15\uC740 \uC544\uD514\uACFC \uCC3D\uD53C\uB97C \uB3D9\uC2DC\uC5D0 \uBD80\uC815\uB2F9\uD558\uB294 \uACBD\uD5D8\uC774 \uB429\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC6C3\uC740 \uD559\uC0DD\uB4E4\uC744 \uACF5\uAC1C\uC801\uC73C\uB85C \uC57C\uB2E8\uCE5C\uB2E4"
        spokenResponse: "\uB204\uAC00 \uC6C3\uC5C8\uC5B4! \uC804\uBD80 \uC774\uB9AC \uC640!"
        quality: 0
        rationale: "\uACF5\uAC1C \uBB38\uCC45\uC740 \uC7A5\uBA74\uC744 \uB354 \uD06C\uAC8C \uB9CC\uB4E4\uC5B4 \uB118\uC5B4\uC9C4 \uD559\uC0DD\uC744 \uC0AC\uAC74\uC758 \uC911\uC2EC\uC5D0 \uB354 \uC624\uB798 \uC138\uC6CC \uB461\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: Schoolyard.RiskyClimb.05
    trigger: "\uC704\uD5D8 \uD589\uB3D9"
    stage: 3
    studentPersona: {fileID: 11400000, guid: f4a8add639795e14b8aeb9ff20ec000b, type: 2}
    crisisType: 1
    teacherGoals: 0400000003000000
    safetyFlags: 00000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uC704\uD5D8 \uD589\uB3D9"
      studentLine: "\uC62C\uB77C\uAC00\uC9C0 \uB9D0\uB77C\uACE0\uB9CC \uD558\uC9C0 \uB9C8\uC694! \uC548 \uB0B4\uB824\uAC00\uC694!"
      observation: "\uD654\uAC00 \uB09C \uCC44 \uCCA0\uBD09 \uAD6C\uC870\uBB3C \uC704\uB85C \uC62C\uB77C\uAC00 \uB0B4\uB824\uC624\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
      entryGesture: 5
      gestureIntensity: 0.75
      options:
      - label: "\uC548\uC804\uC744 \uC9C0\uD0A4\uBA70 \uB0B4\uB824\uC62C \uBC29\uBC95\uC744 \uACE0\uB974\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uB5A8\uC5B4\uC9C8\uAE4C \uBD10 \uAC71\uC815\uB3FC\uC11C \uADF8\uB798. \uC0AC\uB2E4\uB9AC \uCABD\uC73C\uB85C \uB0B4\uB824\uC62C\uC9C0, \uC120\uC0DD\uB2D8 \uC190 \uC7A1\uACE0 \uB0B4\uB824\uC62C\uC9C0 \uACE8\uB77C \uC918. \uAE30\uB2E4\uB9B4\uAC8C."
        quality: 3
        rationale: "\uC548\uC804 \uD504\uB808\uC774\uBC0D\uACFC \uC120\uD0DD\uAD8C: \uAE08\uC9C0\uC5B4 \uB300\uC2E0 \uAC71\uC815\uC744 \uB9D0\uD558\uACE0 \uD558\uAC15 \uBC29\uBC95\uC744 \uD559\uC0DD\uC774 \uACE0\uB974\uAC8C \uD574 \uD798\uACA8\uB8E8\uAE30\uB97C \uD53C\uD569\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uAC15\uD558\uAC8C \uC9C0\uC2DC\uD55C\uB2E4"
        spokenResponse: "\uB2F9\uC7A5 \uC548 \uB0B4\uB824\uC640? \uC14B \uC140 \uAC70\uC57C."
        quality: 0
        rationale: "\uCE74\uC6B4\uD2B8\uB2E4\uC6B4 \uC555\uBC15\uC740 \uB192\uC740 \uACF3\uC5D0\uC11C\uC758 \uCDA9\uB3D9\uC801 \uC6C0\uC9C1\uC784\uC744 \uBD80\uB97C \uC218 \uC788\uB294 \uAC00\uC7A5 \uC704\uD5D8\uD55C \uB300\uC751\uC785\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
      - label: "\uAD00\uC2EC\uC744 \uB04A\uACE0 \uAE30\uB2E4\uB9B0\uB2E4"
        spokenResponse: "\uAD00\uC2EC \uC548 \uC904 \uAC70\uC57C. \uB0B4\uB824\uC624\uBA74 \uB9D0\uD574."
        quality: 1
        rationale: "\uAD00\uC2EC \uCC28\uB2E8 \uC804\uB7B5\uC740 \uC9C0\uC0C1\uC5D0\uC11C\uB294 \uC720\uD6A8\uD560 \uC218 \uC788\uC73C\uB098 \uCD94\uB77D \uC704\uD5D8 \uC0C1\uD669\uC5D0\uC11C\uB294 \uC548\uC804 \uBC29\uCE58\uAC00 \uB429\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
