    beat:
      title: "\uB180\uC774 \uBCF5\uADC0 \uC911\uC7AC"
      studentLine: "\u2026\uB2E4\uC2DC \uAEF4\uB3C4 \uB3FC\uC694? \uC7E4\uB124\uAC00 \uC2EB\uB2E4\uACE0 \uD558\uBA74 \uC5B4\uB5A1\uD574\uC694."
      observation: "\uC9C4\uC815\uB41C \uB4A4 \uACBD\uAE30\uC7A5 \uAC00\uC7A5\uC790\uB9AC\uC5D0\uC11C \uBC1C\uB05D\uC73C\uB85C \uB545\uC744 \uADF8\uC73C\uBA70 \uB208\uCE58\uB97C \uBD05\uB2C8\uB2E4."
      entryGesture: 11
      gestureIntensity: 0.5
      options:
      - label: "\uC791\uC740 \uC5ED\uD560\uB85C \uC7AC\uC9C4\uC785\uC2DC\uD0A4\uACE0 \uACC1\uC5D0 \uC120\uB2E4"
        spokenResponse: "\uB2E4\uC74C \uACF5\uACA9 \uB54C \uC2A4\uB85C\uC778\uBD80\uD130 \uB9E1\uC544 \uBCF4\uC790. \uC120\uC0DD\uB2D8\uC774 \uC606 \uB77C\uC778\uC5D0 \uC11C \uC788\uC744\uAC8C."
        quality: 3
        rationale: "\uC5ED\uD560 \uAE30\uBC18 \uC7AC\uC9C4\uC785: \uD611\uC0C1\uC774 \uD544\uC694 \uC5C6\uB294 \uC791\uC740 \uC5ED\uD560\uB85C \uBCF5\uADC0 \uBB38\uD131\uC744 \uB0AE\uCD94\uACE0 \uAD50\uC0AC\uAC00 \uADFC\uC811 \uC9C0\uC6D0\uD569\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC804\uCCB4\uC5D0\uAC8C \uBCF5\uADC0\uB97C \uC120\uC5B8\uD55C\uB2E4"
        spokenResponse: "\uC598\uB4E4\uC544, \uC9C0\uD638 \uB2E4\uC2DC \uB4E4\uC5B4\uAC04\uB2E4!"
        quality: 2
        rationale: "\uC120\uC758\uC758 \uC120\uC5B8\uC774\uC9C0\uB9CC \uC804\uC6D0\uC758 \uC2DC\uC120\uC744 \uB2E4\uC2DC \uBAA8\uC544 \uC7AC\uC9C4\uC785 \uBD80\uB2F4\uC744 \uD0A4\uC6B8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC2A4\uC2A4\uB85C \uB9D0\uD558\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uB124\uAC00 \uC9C1\uC811 \uAC00\uC11C \uB07C\uC6CC \uB2EC\uB77C\uACE0 \uD574 \uBD10."
        quality: 1
        rationale: "\uAC70\uC808\uB2F9\uD55C \uC9C1\uD6C4\uC758 \uC7AC\uD611\uC0C1 \uC694\uAD6C\uB294 \uC2E4\uD328 \uD655\uB960\uC774 \uB192\uC740 \uACFC\uC81C\uB97C \uD63C\uC790 \uC9C0\uAC8C \uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
