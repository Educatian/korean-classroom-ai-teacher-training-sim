      studentLine: "\uC549\uC544\uC11C \uD55C \uBB38\uC7A5\uB9CC \uB9D0\uD574 \uBCFC\uAC8C\uC694."
      observation: "\uD559\uC0DD\uC774 \uC0C1\uCCB4\uB97C \uC138\uC6B0\uACE0 \uAD50\uC0AC\uC640 \uC9E7\uAC8C \uC544\uC774\uCEE8\uD0DD\uD569\uB2C8\uB2E4."
      entryGesture: 11
      gestureIntensity: 0.52
      options:
      - label: "\uC791\uC740 \uCC38\uC5EC\uB97C \uC778\uC815\uD558\uACE0 \uACBD\uCCAD
          \uADDC\uCE59\uACFC \uD6C4\uC18D \uC810\uAC80\uC744 \uC5F0\uACB0\uD55C\uB2E4"
        spokenResponse: "\uC88B\uC544. \uD55C \uBB38\uC7A5\uC774\uBA74 \uCDA9\uBD84\uD574.
          \uCE5C\uAD6C\uB4E4\uC740 \uB07C\uC5B4\uB4E4\uC9C0 \uC54A\uACE0 \uB4E3\uACE0,
          \uB05D\uB09C \uB4A4\uC5D0 \uB098\uC640 \uB2E4\uC74C \uB2E8\uACC4\uB97C
          \uC815\uD558\uC790."
        quality: 3
        rationale: "\uC791\uC740 \uC131\uACF5 \uC778\uC815\uACFC \uACBD\uCCAD \uADDC\uCE59 \uBCF5\uC6D0: \uC131\uACF5 \uAE30\uC900\uC744 \uD55C \uBB38\uC7A5\uC73C\uB85C \uC7A1\uACE0 \uB610\uB798 \uACBD\uCCAD\uC744 \uD568\uAED8 \uBCF5\uC6D0\uD574 \uC7AC\uB3C4\uC804\uC774 \uC548\uC804\uD558\uB2E4\uB294 \uACBD\uD5D8\uC744 \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uAD1C\uCC2E\uC544\uC84C\uC73C\uB2C8 \uC804\uCCB4 \uBC1C\uD45C\uB97C
          \uC694\uAD6C\uD55C\uB2E4"
        spokenResponse: "\uC2DC\uC791\uD588\uC73C\uB2C8 \uB05D\uAE4C\uC9C0 \uB2E4
          \uBC1C\uD45C\uD574\uC57C\uC9C0."
        quality: 1
        rationale: "\uC804\uCCB4 \uBC1C\uD45C \uC694\uAD6C\uB294 \uD68C\uBCF5 \uC9C1\uD6C4\uC758 \uC131\uACF5 \uACBD\uD5D8\uC744 \uB2E4\uC2DC \uC2E4\uD328 \uC704\uD5D8\uC73C\uB85C \uBC14\uAFC9\uB2C8\uB2E4. \uAE30\uC900\uC740 \uC791\uAC8C \uC720\uC9C0\uD574\uC57C \uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uACFC\uB3C4\uD558\uAC8C \uACF5\uAC1C \uCE6D\uCC2C\uD55C\uB2E4"
        spokenResponse: "\uC598\uB4E4\uC544, \uD070 \uBC15\uC218! \uB4DC\uB514\uC5B4
          \uD574\uB0C8\uB124."
        quality: 2
        rationale: "\uD070 \uACF5\uAC1C \uCE6D\uCC2C\uC740 \uC120\uC758\uC9C0\uB9CC \uC8FC\uBAA9 \uBD80\uB2F4\uC744 \uB2E4\uC2DC \uD0A4\uC6B8 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC9E7\uACE0 \uC870\uC6A9\uD55C \uC778\uC815\uC774 \uD68C\uBCF5 \uB2E8\uACC4\uC5D0\uB294 \uB354 \uB9DE\uC2B5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
