  scenarioId: CircleDiscussionResponse
  displayName: "\uC11C\uD074 \uD1A0\uB860\u00B7\uBC1C\uD45C \uC704\uAE30 \uB300\uC751"
  sceneId: 2
  researchNotes: "\uBE44\uD2B8 \uD14D\uC2A4\uD2B8, \uB300\uC751 \uC120\uD0DD\uC9C0, \uC5ED\uB7C9 \uBAA9\uD45C\uB294 \uC774 \uC5D0\uC14B\uC758 Inspector\uC5D0\uC11C \uC9C1\uC811 \uC218\uC815\uD569\uB2C8\uB2E4."
  beats:
  - scenarioId: CircleDiscussion.PeerDisagreement.01
    trigger: "\uBC1C\uD45C \uCC28\uB840 \uD68C\uD53C"
    stage: 0
    studentPersona: {fileID: 11400000, guid: 1cb1c446b06c4714bafefac9ca51a1a5, type: 2}
    crisisType: 3
    teacherGoals: 0200000001000000
    safetyFlags: 0300000001000000
    peerAttention: 2
    presentationAvoidance: 0
    beat:
      title: "\uBC1C\uD45C \uCC28\uB840 \uD68C\uD53C"
      studentLine: "\uC800 \uBC1C\uD45C \uC548 \uD560\uB798\uC694. \uB2E4 \uCCD0\uB2E4\uBCF4\uC796\uC544\uC694."
      observation: "\uD559\uC0DD\uC774 \uC0C1\uCCB4\uB97C \uAE34\uC7A5\uC2DC\uD0A4\uACE0
        \uAD50\uC0AC\uB97C \uBC14\uB77C\uBCF4\uBA70 \uBC1C\uD45C\uB97C \uAC70\uBD80\uD569\uB2C8\uB2E4.
        \uC6D0\uD615 \uBC30\uCE58\uC5D0\uC11C\uB294 \uB610\uB798\uC758 \uC2DC\uC120\uC774
        \uC555\uBC15\uC73C\uB85C \uB290\uAEF4\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
      entryGesture: 3
      gestureIntensity: 0.52
      options:
      - label: "\uACF5\uAC1C \uC555\uBC15\uC744 \uB0AE\uCD94\uACE0 \uBC1C\uD45C \uBC29\uC2DD\uC744
          \uC120\uD0DD\uD558\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uC9C0\uAE08 \uBC14\uB85C \uC55E\uC5D0 \uC11C\uC9C0 \uC54A\uC544\uB3C4
          \uB3FC. \uC549\uC544\uC11C \uCCAB \uBB38\uC7A5\uB9CC \uC77D\uAC70\uB098,
          \uB0B4\uAC00 \uC606\uC5D0\uC11C \uAC19\uC774 \uC2DC\uC791\uD558\uB294 \uBC29\uBC95
          \uC911 \uACE8\uB77C\uBCF4\uC790."
        quality: 3
        rationale: "\uACF5\uAC1C \uC555\uBC15 \uC644\uD654\uC640 \uBC29\uC2DD \uC120\uD0DD\uAD8C: \uBC1C\uD45C \uD615\uD0DC\uB97C \uC870\uC815 \uAC00\uB2A5\uD55C \uC120\uD0DD\uC9C0\uB85C \uBC14\uAFD4 \uB610\uB798 \uC2DC\uC120 \uBD80\uB2F4\uC744 \uB0AE\uCD94\uBA74\uC11C \uCC38\uC5EC \uC790\uCCB4\uB294 \uC720\uC9C0\uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uBAA8\uB450 \uAE30\uB2E4\uB9B0\uB2E4\uACE0 \uC7AC\uCD09\uD55C\uB2E4"
        spokenResponse: "\uCE5C\uAD6C\uB4E4\uC774 \uB2E4 \uAE30\uB2E4\uB9AC\uC796\uC544.
          \uBE68\uB9AC \uC2DC\uC791\uD574."
        quality: 0
        rationale: "\uC804\uCCB4 \uB300\uAE30\uB97C \uC0C1\uAE30\uC2DC\uD0A4\uB294 \uC7AC\uCD09\uC740 \uB610\uB798 \uC555\uBC15\uC744 \uAD50\uC0AC\uAC00 \uC99D\uD3ED\uD558\uB294 \uC148\uC774 \uB418\uC5B4 \uD68C\uD53C\uB97C \uAD73\uD799\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
      - label: "\uBC1C\uD45C\uB97C \uC989\uC2DC \uBA74\uC81C\uD55C\uB2E4"
        spokenResponse: "\uADF8\uB7FC \uC624\uB298\uC740 \uC544\uC608 \uD558\uC9C0
          \uB9C8."
        quality: 2
        rationale: "\uC989\uC2DC \uBA74\uC81C\uB294 \uC555\uBC15\uC744 \uBA48\uCD94\uC9C0\uB9CC \uB9D0\uD22C\uAC00 \uB2E8\uC808\uC801\uC774\uACE0 \uC7AC\uB3C4\uC804 \uACBD\uB85C\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4. \uC720\uC608\uC640 \uB300\uC548 \uBC29\uC2DD \uC81C\uC548\uC774 \uB354 \uB0AB\uC2B5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
  - scenarioId: CircleDiscussion.PresentationTurn.02
    trigger: "\uB610\uB798 \uB07C\uC5B4\uB4E4\uAE30\uC640 \uC870\uB871"
    stage: 1
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 4
    teacherGoals: 0000000003000000
    safetyFlags: 0300000000000000
    peerAttention: 3
    presentationAvoidance: 1
    beat:
      title: "\uB610\uB798 \uB07C\uC5B4\uB4E4\uAE30\uC640 \uC870\uB871"
      studentLine: "\uC7E4\uAC00 \uB610 \uBE44\uC6C3\uC5C8\uC5B4\uC694! \uB9D0\uD558\uAE30
        \uC2EB\uC5B4\uC694."
      observation: "\uC606 \uD559\uC0DD\uC758 \uC6C3\uC74C \uB4A4 \uBC1C\uD45C\uC790\uAC00 \uC0C1\uB300\uB97C \uAC00\uB9AC\uD0A4\uBA70 \uBAA9\uC18C\uB9AC\uB97C \uB192\uC785\uB2C8\uB2E4."
      entryGesture: 8
      gestureIntensity: 0.68
      options:
      - label: "\uB07C\uC5B4\uB4E4\uAE30\uB97C \uBA48\uCD94\uACE0 \uBC1C\uD45C\uC790\uC758
          \uC548\uC804\uC744 \uBA3C\uC800 \uD655\uC778\uD55C\uB2E4"
        spokenResponse: "\uC9C0\uAE08\uC740 \uC11C\uB85C\uC758 \uB9D0\uC744 \uB04A\uC9C0
          \uC54A\uB294 \uADDC\uCE59\uC73C\uB85C \uB3CC\uC544\uAC00\uC790. \uB124
          \uBC1C\uD45C\uB294 \uC7A0\uAE50 \uBA48\uCD94\uACE0, \uB0B4\uAC00 \uC606\uC5D0\uC11C
          \uB2E4\uC2DC \uC2DC\uC791\uD560 \uC900\uBE44\uB97C \uB3C4\uC6B8\uAC8C."
        quality: 3
        rationale: "\uBC1C\uC5B8 \uC9C8\uC11C \uD68C\uBCF5\uACFC \uBC1C\uD45C\uC790 \uBCF4\uD638: \uC798\uC798\uBABB \uD310\uC815\uBCF4\uB2E4 \uC548\uC804\uD55C \uADDC\uCE59 \uBCF5\uC6D0\uC744 \uC55E\uC138\uC6CC \uBC1C\uD45C\uC790\uC758 \uC874\uC5C4\uC744 \uC9C0\uD0A4\uACE0 \uC7AC\uC2DC\uC791\uC744 \uB3D5\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uB204\uAC00 \uBA3C\uC800 \uC798\uBABB\uD588\uB294\uC9C0 \uACF5\uAC1C\uC801\uC73C\uB85C
          \uBB3B\uB294\uB2E4"
        spokenResponse: "\uB204\uAC00 \uBA3C\uC800 \uBE44\uC6C3\uC5C8\uC5B4? \uC9C0\uAE08
          \uB2E4 \uB9D0\uD574 \uBD10."
        quality: 1
        rationale: "\uAC00\uD574\uC790\uB97C \uACF5\uAC1C\uC801\uC73C\uB85C \uCC3E\uB294 \uC9C8\uBB38\uC740 \uC870\uB871 \uC7A5\uBA74\uC744 \uC7AC\uC810\uD654\uD558\uACE0 \uBC1C\uD45C\uC790\uB97C \uB2E4\uC2DC \uAD6C\uACBD\uAC70\uB9AC\uB85C \uB9CC\uB4ED\uB2C8\uB2E4. \uADDC\uCE59 \uBCF5\uC6D0\uC774 \uC6B0\uC120\uC785\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
      - label: "\uC608\uBBFC\uD558\uAC8C \uBC18\uC751\uD558\uC9C0 \uB9D0\uB77C\uACE0
          \uD55C\uB2E4"
        spokenResponse: "\uADF8 \uC815\uB3C4\uB294 \uADF8\uB0E5 \uB118\uACA8. \uACC4\uC18D
          \uBC1C\uD45C\uD574."
        quality: 0
        rationale: "\uB118\uC5B4\uAC00\uB77C\uB294 \uB9D0\uC740 \uC870\uB871\uC744 \uC2B9\uC778\uD558\uB294 \uBA54\uC2DC\uC9C0\uAC00 \uB418\uC5B4 \uBC1C\uD45C\uC790\uC758 \uC548\uC804\uAC10\uC744 \uBB34\uB108\uB728\uB9BD\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
  - scenarioId: CircleDiscussion.PeerDisagreement.03
    trigger: "\uC790\uB8CC \uBC00\uCE58\uAE30\uC640 \uD56D\uC758"
    stage: 2
    studentPersona: {fileID: 11400000, guid: 1cb1c446b06c4714bafefac9ca51a1a5, type: 2}
    crisisType: 3
    teacherGoals: 0400000001000000
    safetyFlags: 0300000001000000
    peerAttention: 2
    presentationAvoidance: 0
    beat:
      title: "\uC790\uB8CC \uBC00\uCE58\uAE30\uC640 \uD56D\uC758"
      studentLine: "\uC81C \uB9D0\uC740 \uC544\uBB34\uB3C4 \uC548 \uB4E3\uC796\uC544\uC694!"
      observation: "\uD559\uC0DD\uC774 \uBC1C\uD45C \uC790\uB8CC\uB97C \uBC00\uACE0 \uBAB8\uC744 \uC55E\uC73C\uB85C \uAE30\uC6B8\uC785\uB2C8\uB2E4."
      entryGesture: 9
      gestureIntensity: 0.72
      options:
      - label: "\uAC70\uB9AC\uB97C \uD655\uBCF4\uD558\uACE0 \uC190\uC758 \uC548\uC804\uACFC
          \uC120\uD0DD\uC9C0\uB97C \uC9E7\uAC8C \uC81C\uC2DC\uD55C\uB2E4"
        spokenResponse: "\uB124 \uB9D0\uC744 \uB4E4\uC744 \uC900\uBE44\uAC00 \uB418\uC5B4
          \uC788\uC5B4. \uC790\uB8CC\uB294 \uC5EC\uAE30 \uB450\uACE0, \uC790\uB9AC\uC5D0
          \uC549\uC544 \uB9D0\uD560\uC9C0 \uB098\uC640 \uC7A0\uAE50 \uC606\uC73C\uB85C
          \uAC08\uC9C0 \uC120\uD0DD\uD574 \uC918."
        quality: 3
        rationale: "\uAC70\uB9AC \uD655\uBCF4\uC640 \uC9E7\uC740 \uC548\uC804 \uD655\uC778, \uC120\uD0DD\uAD8C: \uBB3C\uAC74\uACFC \uC190\uC758 \uC548\uC804\uC744 \uD655\uC778\uD558\uACE0 \uB9D0\uD560 \uBC29\uC2DD\uC744 \uACE0\uB974\uAC8C \uD574 \uD56D\uC758\uB97C \uB300\uD654\uB85C \uC804\uD658\uD569\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC790\uB8CC\uB97C \uBE7C\uC557\uACE0 \uC549\uC73C\uB77C\uACE0 \uBA85\uB839\uD55C\uB2E4"
        spokenResponse: "\uADF8\uAC70 \uB0B4\uB824\uB194. \uB2F9\uC7A5 \uC549\uC544."
        quality: 0
        rationale: "\uBB3C\uAC74 \uD68C\uC218\uC640 \uCC29\uC11D \uBA85\uB839\uC740 \uD798\uACA8\uB8E8\uAE30\uB97C \uC120\uC5B8\uD558\uB294 \uAC83\uACFC \uAC19\uC544 \uC2E0\uCCB4\uC801 \uAE34\uC7A5\uC744 \uB192\uC785\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
      - label: "\uAE34 \uC774\uC720 \uC124\uBA85\uC744 \uC694\uAD6C\uD55C\uB2E4"
        spokenResponse: "\uC65C \uADF8\uB7F0 \uD589\uB3D9\uC744 \uD588\uB294\uC9C0
          \uCC98\uC74C\uBD80\uD130 \uC790\uC138\uD788 \uC124\uBA85\uD574."
        quality: 1
        rationale: "\uC989\uC2DC \uC6D0\uC778 \uC124\uBA85 \uC694\uAD6C\uB294 \uAC01\uC131\uC774 \uB192\uC740 \uC0C1\uD0DC\uC5D0\uC11C \uCC98\uB9AC \uBD80\uB2F4\uC744 \uB354\uD569\uB2C8\uB2E4. \uC9C4\uC815 \uD6C4 \uBE44\uACF5\uAC1C\uB85C \uB4E3\uB294 \uAC83\uC774 \uC815\uD655\uD558\uACE0 \uC548\uC804\uD569\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: CircleDiscussion.PresentationTurn.04
    trigger: "\uC790\uB9AC \uC774\uD0C8 \uC2DC\uB3C4"
    stage: 2
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 4
    teacherGoals: 0300000005000000
    safetyFlags: 0300000000000000
    peerAttention: 3
    presentationAvoidance: 1
    beat:
      title: "\uC790\uB9AC \uC774\uD0C8 \uC2DC\uB3C4"
      studentLine: "\uC5EC\uAE30 \uBABB \uC788\uACA0\uC5B4\uC694. \uB098\uAC08 \uAC70\uC608\uC694."
      observation: "\uC758\uC790\uAC00 \uB4A4\uB85C \uBC00\uB9AC\uACE0 \uD559\uC0DD\uC774 \uCD9C\uAD6C \uCABD\uC73C\uB85C \uBAB8\uC744 \uB3CC\uB9BD\uB2C8\uB2E4."
      entryGesture: 4
      gestureIntensity: 0.66
      options:
      - label: "\uB9C9\uC9C0 \uC54A\uACE0 \uB3D9\uD589 \uAC00\uB2A5\uD55C \uC548\uC815
          \uACF5\uAC04\uACFC \uBCF5\uADC0 \uC2DC\uC810\uC744 \uC81C\uC2DC\uD55C\uB2E4"
        spokenResponse: "\uC54C\uACA0\uC5B4. \uBB38 \uC55E \uC548\uC815 \uC790\uB9AC\uB85C
          \uAC19\uC774 \uC774\uB3D9\uD558\uC790. 3\uBD84 \uB4A4\uC5D0 \uB0B4\uAC00
          \uB2E4\uC2DC \uD655\uC778\uD558\uACE0 \uB3CC\uC544\uC62C \uBC29\uBC95\uC744
          \uC815\uD558\uC790."
        quality: 3
        rationale: "\uC774\uB3D9 \uD5C8\uC6A9\uACFC \uBCF5\uADC0 \uAD6C\uC870\uD654: \uC774\uD0C8\uC744 \uB9C9\uC9C0 \uC54A\uB418 \uBAA9\uC801\uC9C0\uC640 \uC7AC\uD655\uC778 \uC2DC\uC810\uC744 \uD568\uAED8 \uC815\uD574 \uD798\uACA8\uB8E8\uAE30 \uC5C6\uC774 \uAD00\uCC30 \uAC00\uB2A5\uD55C \uACBD\uB85C\uB97C \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uBB38\uC744 \uB9C9\uACE0 \uC790\uB9AC\uC5D0 \uC549\uD78C\uB2E4"
        spokenResponse: "\uC218\uC5C5 \uC911\uC5D0\uB294 \uBABB \uB098\uAC00. \uC790\uB9AC\uC5D0
          \uC549\uC544."
        quality: 0
        rationale: "\uCD9C\uAD6C \uBD09\uC1C4\uB294 \uC2E0\uCCB4\uC801 \uB300\uCE58\uB85C \uBC88\uC9C0\uAE30 \uC26C\uC6B4 \uAC00\uC7A5 \uC704\uD5D8\uD55C \uC120\uD0DD\uC785\uB2C8\uB2E4. \uC774\uB3D9 \uC695\uAD6C\uB294 \uB9C9\uAE30\uBCF4\uB2E4 \uAD6C\uC870\uD654\uD574\uC57C \uD569\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
      - label: "\uD63C\uC790 \uB098\uAC00\uAC8C \uB454\uB2E4"
        spokenResponse: "\uAC00\uACE0 \uC2F6\uC73C\uBA74 \uD63C\uC790 \uB098\uAC00."
        quality: 1
        rationale: "\uD63C\uC790 \uB0B4\uBCF4\uB0B4\uBA74 \uCDA9\uB3CC\uC740 \uD53C\uD558\uC9C0\uB9CC \uAD00\uCC30\uACFC \uBCF5\uADC0 \uC5F0\uACB0\uC774 \uB04A\uAE41\uB2C8\uB2E4. \uB3D9\uD589 \uB610\uB294 \uC7AC\uD655\uC778 \uC2DC\uC810 \uC57D\uC18D\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: CircleDiscussion.PeerDisagreement.05
    trigger: "\uBE44\uACF5\uAC1C \uC7AC\uC811\uCD09"
    stage: 4
    studentPersona: {fileID: 11400000, guid: 1cb1c446b06c4714bafefac9ca51a1a5, type: 2}
    crisisType: 3
    teacherGoals: 0200000000000000
    safetyFlags: 0300000001000000
    peerAttention: 2
    presentationAvoidance: 0
    beat:
      title: "\uBE44\uACF5\uAC1C \uC7AC\uC811\uCD09"
      studentLine: "\uCE5C\uAD6C\uB4E4 \uC55E\uC5D0\uC11C\uB294 \uB9D0\uD558\uAE30
        \uC2EB\uC5B4\uC694."
      observation: "\uD559\uC0DD\uC758 \uBAA9\uC18C\uB9AC\uB294 \uB0AE\uC544\uC84C\uC9C0\uB9CC \uB610\uB798\uB97C \uACC4\uC18D \uC0B4\uD54D\uB2C8\uB2E4."
      entryGesture: 3
      gestureIntensity: 0.56
      options:
      - label: "\uBC1C\uC5B8\uC744 \uC720\uC608\uD558\uACE0 \uBE44\uACF5\uAC1C \uD655\uC778
          \uC2DC\uAC04\uC744 \uC57D\uC18D\uD55C\uB2E4"
        spokenResponse: "\uC9C0\uAE08 \uC124\uBA85\uD558\uC9C0 \uC54A\uC544\uB3C4
          \uB3FC. \uBAA8\uB460 \uD65C\uB3D9\uC774 \uC2DC\uC791\uB418\uBA74 \uB0B4\uAC00
          \uC606\uC5D0\uC11C \uC870\uC6A9\uD788 \uD655\uC778\uD560\uAC8C."
        quality: 3
        rationale: "\uBC1C\uC5B8 \uC720\uC608\uC640 \uBE44\uACF5\uAC1C \uC804\uD658: \uACF5\uAC1C \uC124\uBA85 \uBD80\uB2F4\uC744 \uC5C6\uC560\uACE0 \uC870\uC6A9\uD55C \uD655\uC778 \uC2DC\uC810\uC744 \uC57D\uC18D\uD574 \uB610\uB798 \uC2DC\uC120\uC5D0\uC11C \uD68C\uBCF5 \uACF5\uAC04\uC744 \uBD84\uB9AC\uD569\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uCE5C\uAD6C\uB4E4 \uC55E\uC5D0\uC11C \uC624\uD574\uB97C \uD480\uAC8C
          \uD55C\uB2E4"
        spokenResponse: "\uB2E4 \uAC19\uC774 \uB4E3\uACE0 \uC788\uC73C\uB2C8 \uC9C0\uAE08
          \uC124\uBA85\uD558\uBA74 \uB3FC."
        quality: 0
        rationale: "\uC804\uCCB4 \uC55E \uD574\uBA85 \uC694\uAD6C\uB294 \uB0AE\uC544\uC9C4 \uAC01\uC131\uC744 \uB2E4\uC2DC \uACF5\uAC1C \uBB34\uB300\uB85C \uB04C\uC5B4\uC62C\uB824 \uC7AC\uACA9\uC559 \uC704\uD5D8\uC744 \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
      - label: "\uC544\uBB34 \uB9D0 \uC5C6\uC774 \uD65C\uB3D9\uC5D0\uC11C \uC81C\uC678\uD55C\uB2E4"
        spokenResponse: "\uADF8\uB7FC \uC774\uBC88 \uD65C\uB3D9\uC740 \uBE60\uC838."
        quality: 1
        rationale: "\uB9D0\uC5C6\uC774 \uC81C\uC678\uD558\uBA74 \uC790\uADF9\uC740 \uC904\uC9C0\uB9CC \uD559\uC0DD\uC740 \uBC30\uC81C\uB85C \uACBD\uD5D8\uD569\uB2C8\uB2E4. \uC9E7\uC740 \uC608\uACE0\uC640 \uC7AC\uC811\uCD09 \uC57D\uC18D\uC774 \uD568\uAED8 \uAC00\uC57C \uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
