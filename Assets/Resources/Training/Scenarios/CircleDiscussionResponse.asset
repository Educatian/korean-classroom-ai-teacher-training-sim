      - label: "\uC790\uB8CC\uB97C \uBE7C\uC557\uACE0 \uC549\uC73C\uB77C\uACE0 \uBA85\uB839\uD55C\uB2E4"
        spokenResponse: "\uADF8\uAC70 \uB0B4\uB824\uB194. \uB2F9\uC7A5 \uC549\uC544."
        quality: 0
        rationale: "\uACF5\uAC1C\uC801 \uD1B5\uC81C\uC640 \uC555\uBC15\uC740 \uC704\uAE30
          \uAC15\uB3C4\uB97C \uB192\uC77C \uC218 \uC788\uC2B5\uB2C8\uB2E4."
        resultingAffect: 3
