  m_Name: RecoveryRoomResponse
  m_EditorClassIdentifier: AdieLab.TeacherTraining::AdieLab.TeacherTraining.TrainingScenarioAsset
  scenarioId: RecoveryRoomResponse
  displayName: "\uC548\uC815 \uACF5\uAC04 1:1 \uD68C\uBCF5 \uB300\uD654"
  sceneId: 3
  researchNotes: "\uD68C\uBCF5 \uB2E8\uACC4 1:1 \uB300\uD654 \uD6C8\uB828. \uBE44\uD2B8\u00B7\uC120\uD0DD\uC9C0\u00B7\uC5ED\uB7C9 \uBAA9\uD45C\uB294 Inspector\uC5D0\uC11C \uC218\uC815\uD569\uB2C8\uB2E4. \uC138\uC774\uD504\uAC00\uB529: \uBB38 \uBC18\uAC1C\uBC29, \uBCF5\uB3C4 \uCC3D \uAC00\uC2DC\uC131 \uC720\uC9C0."
  beats:
  - scenarioId: RecoveryRoom.Arrival.01
    trigger: "\uB3C4\uCC29\uACFC \uC9C4\uC815 \uD655\uC778"
    stage: 3
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 0
    teacherGoals: 0200000001000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uB3C4\uCC29\uACFC \uC9C4\uC815 \uD655\uC778"
      studentLine: "\u2026\uC5EC\uAE30 \uC65C \uC628 \uAC70\uC608\uC694. \uC800 \uD63C\uB0B4\uB824\uACE0\uC694?"
      observation: "\uC5B4\uAE68\uAC00 \uAD73\uC5B4 \uC788\uACE0 \uBB38 \uCABD\uC744 \uB4F1\uC9C0\uACE0 \uC549\uC73C\uB824 \uD569\uB2C8\uB2E4. \uD638\uD761\uC740 \uC544\uC9C1 \uBE60\uB985\uB2C8\uB2E4."
      entryGesture: 3
      gestureIntensity: 0.5
      options:
      - label: "\uAC10\uC815\uC744 \uD655\uC778\uD558\uACE0 \uBA38\uBB34\uB294 \uBC29\uC2DD\uC744 \uC120\uD0DD\uD558\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uD63C\uB0B4\uB824\uACE0 \uC628 \uAC8C \uC544\uB2C8\uC57C. \uC228 \uACE0\uB97C \uC2DC\uAC04 \uBA3C\uC800 \uAC16\uC790. \uCFE0\uC158\uC5D0 \uC549\uC744\uC9C0 \uCC3D\uAC00\uC5D0 \uC124\uC9C0 \uACE8\uB77C\uB3C4 \uB3FC."
        quality: 3
        rationale: "\uBAA9\uC801 \uBA85\uB8CC\uD654\uC640 \uC120\uD0DD\uAD8C \uC81C\uACF5: \uCC98\uBC8C \uACF5\uAC04\uC774 \uC544\uB2D8\uC744 \uBA3C\uC800 \uBC1D\uD788\uACE0 \uBA38\uBB34\uB294 \uBC29\uC2DD\uC744 \uD559\uC0DD\uC774 \uC815\uD558\uAC8C \uD574 \uC548\uC804\uAC10\uC744 \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uBC14\uB85C \uC0AC\uAC74 \uC124\uBA85\uC744 \uC694\uAD6C\uD55C\uB2E4"
        spokenResponse: "\uC774\uC81C \uC870\uC6A9\uD558\uB2C8\uAE4C \uC544\uAE4C \uBB34\uC2A8 \uC77C\uC774\uC5C8\uB294\uC9C0 \uCC98\uC74C\uBD80\uD130 \uB9D0\uD574 \uBD10."
        quality: 1
        rationale: "\uC9C4\uC815 \uD655\uC778 \uC5C6\uC774 \uBCF5\uAE30\uB97C \uC694\uAD6C\uD558\uBA74 \uAC01\uC131\uC774 \uB2E4\uC2DC \uC62C\uB77C\uAC11\uB2C8\uB2E4. \uC548\uC815 \uC2E0\uD638\uB97C \uBA3C\uC800 \uD655\uC778\uD574\uC57C \uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC798\uBABB\uC744 \uC0C1\uAE30\uC2DC\uD0A8\uB2E4"
        spokenResponse: "\uB124\uAC00 \uC65C \uC5EC\uAE30 \uC654\uB294\uC9C0\uB294 \uC54C\uC9C0? \uAD50\uC2E4\uC5D0\uC11C \uADF8\uB7EC\uBA74 \uC548 \uB418\uB294 \uAC70\uC57C."
        quality: 0
        rationale: "\uACF5\uAC04\uC744 \uCC98\uBC8C\uB85C \uADDC\uC815\uD558\uB294 \uB9D0\uC740 \uC548\uC815 \uACF5\uAC04\uC758 \uC2E0\uB8B0 \uC790\uCCB4\uB97C \uBB34\uB108\uB728\uB9BD\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: RecoveryRoom.NamingFeelings.02
    trigger: "\uAC10\uC815 \uCE74\uB4DC\uB85C \uB9C8\uC74C \uCC3E\uAE30"
    stage: 3
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 0
    teacherGoals: 0200000003000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uAC10\uC815 \uCE74\uB4DC\uB85C \uB9C8\uC74C \uCC3E\uAE30"
      studentLine: "\uBAA8\uB974\uACA0\uC5B4\uC694. \uADF8\uB0E5\u2026 \uB2E4 \uC9DC\uC99D\uB098\uC694."
      observation: "\uAC10\uC815 \uCE74\uB4DC\uB97C \uC55E\uC5D0 \uB450\uACE0 \uC2DC\uC120\uC744 \uD53C\uD569\uB2C8\uB2E4. \uC190\uAC00\uB77D\uC73C\uB85C \uCE74\uB4DC \uBAA8\uC11C\uB9AC\uB97C \uB9CC\uC9C0\uC791\uAC70\uB9BD\uB2C8\uB2E4."
      entryGesture: 1
      gestureIntensity: 0.45
      options:
      - label: "\uAC10\uC815 \uCE74\uB4DC\uB85C \uAC04\uC811 \uD45C\uD604\uC744 \uB3D5\uB294\uB2E4"
        spokenResponse: "\uB9D0\uB85C \uC548 \uD574\uB3C4 \uB3FC. \uC9C0\uAE08 \uB9C8\uC74C\uC774\uB791 \uC81C\uC77C \uAC00\uAE4C\uC6B4 \uCE74\uB4DC\uB97C \uD558\uB098\uB9CC \uACE8\uB77C \uC904\uB798?"
        quality: 3
        rationale: "\uAC04\uC811 \uD45C\uD604 \uB3C4\uAD6C \uC81C\uACF5: \uC5B8\uC5B4\uD654 \uBD80\uB2F4\uC744 \uB0AE\uCD94\uACE0 \uD559\uC0DD\uC774 \uACE0\uB974\uB294 \uBC29\uC2DD\uC73C\uB85C \uAC10\uC815 \uBA85\uBA85\uC744 \uB3D5\uC2B5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uAD50\uC0AC\uAC00 \uAC10\uC815\uC744 \uB300\uC2E0 \uB9D0\uD574 \uC900\uB2E4"
        spokenResponse: "\uD654\uAC00 \uB0AC\uAD6C\uB098. \uD654\uB0A0 \uB9CC\uD588\uC5B4."
        quality: 2
        rationale: "\uACF5\uAC10 \uD45C\uD604\uC774\uC9C0\uB9CC \uAD50\uC0AC\uAC00 \uB2E8\uC815\uD558\uBA74 \uD559\uC0DD\uC758 \uC790\uAE30 \uBA85\uBA85 \uAE30\uD68C\uAC00 \uC904\uC5B4\uB4ED\uB2C8\uB2E4. \uD655\uC778 \uC9C8\uBB38\uC774 \uD568\uAED8 \uAC00\uC57C \uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uAC10\uC815 \uD45C\uD604\uC744 \uC7AC\uCD09\uD55C\uB2E4"
        spokenResponse: "\uC9DC\uC99D\uB09C\uB2E4\uB294 \uB9D0 \uB9D0\uACE0 \uC815\uD655\uD558\uAC8C \uB9D0\uD574\uC57C \uC54C\uC9C0."
        quality: 0
        rationale: "\uD45C\uD604 \uBC29\uC2DD\uC744 \uC9C0\uC801\uD558\uBA74 \uAC10\uC815 \uB300\uD654 \uC790\uCCB4\uB97C \uB2EB\uC544 \uBC84\uB9BD\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: RecoveryRoom.Retelling.03
    trigger: "\uC0AC\uAC74 \uBCF5\uAE30"
    stage: 4
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 3
    teacherGoals: 0000000001000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uC0AC\uAC74 \uBCF5\uAE30"
      studentLine: "\uAC54\uAC00 \uBA3C\uC800 \uBE44\uC6C3\uC5C8\uC5B4\uC694. \uC800\uB9CC \uB9E8\uB0A0 \uD63C\uB098\uC694."
      observation: "\uBAA9\uC18C\uB9AC\uAC00 \uB2E4\uC2DC \uCEE4\uC9C0\uB824 \uD569\uB2C8\uB2E4. \uC0AC\uC2E4\uACFC \uAC10\uC815\uC774 \uC11E\uC5EC \uB098\uC635\uB2C8\uB2E4."
      entryGesture: 2
      gestureIntensity: 0.5
      options:
      - label: "\uBE44\uB09C \uC5C6\uC774 \uC0AC\uC2E4\uACFC \uAC10\uC815\uC744 \uB098\uB220 \uB4E3\uB294\uB2E4"
        spokenResponse: "\uB124\uAC00 \uC5B4\uB5BB\uAC8C \uB290\uAF08\uB294\uC9C0\uB791 \uBB34\uC2A8 \uC77C\uC774 \uC788\uC5C8\uB294\uC9C0, \uB458 \uB2E4 \uB4E3\uACE0 \uC2F6\uC5B4. \uCC9C\uCC9C\uD788, \uC21C\uC11C\uB294 \uB124\uAC00 \uC815\uD574."
        quality: 3
        rationale: "\uC0AC\uC2E4-\uAC10\uC815 \uBD84\uB9AC \uCCAD\uCDE8: \uD310\uC815\uC744 \uBBF8\uB8E8\uACE0 \uC21C\uC11C \uC120\uD0DD\uAD8C\uC744 \uC8FC\uC5B4 \uBC29\uC5B4 \uC5C6\uC774 \uBCF5\uAE30\uD558\uAC8C \uD569\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC0C1\uB300 \uC785\uC7A5\uC744 \uBA3C\uC800 \uB300\uBCC0\uD55C\uB2E4"
        spokenResponse: "\uADF8\uB798\uB3C4 \uAC54 \uC785\uC7A5\uC5D0\uC11C\uB294 \uC7A5\uB09C\uC774\uC5C8\uC744 \uC218\uB3C4 \uC788\uC796\uC544."
        quality: 1
        rationale: "\uC870\uAE30 \uC911\uB9BD\uD654\uB294 \uD3B8\uB4E4\uC9C0 \uC54A\uB294\uB2E4\uB294 \uC2E0\uD638\uAC00 \uC544\uB2C8\uB77C \uB0B4 \uB9D0\uC744 \uBBFF\uC9C0 \uC54A\uB294\uB2E4\uB294 \uC2E0\uD638\uB85C \uC77D\uD788\uAE30 \uC27D\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uD589\uB3D9\uC758 \uACB0\uACFC\uBD80\uD130 \uB530\uC9C4\uB2E4"
        spokenResponse: "\uADF8\uB798\uC11C \uC790\uB8CC\uB97C \uBC00\uC5C8\uC5B4? \uADF8\uAC74 \uBCC0\uBA85\uC774 \uC548 \uB3FC."
        quality: 0
        rationale: "\uBCF5\uAE30 \uB2E8\uACC4\uC758 \uC2EC\uD310\uC740 \uD68C\uBCF5 \uB300\uD654\uB97C \uC9C4\uC220 \uBC29\uC5B4\uB85C \uBC14\uAFC9\uB2C8\uB2E4. \uACB0\uACFC \uB17C\uC758\uB294 \uC548\uC815\uACFC \uC2E0\uB8B0 \uB4A4\uC5D0 \uC640\uC57C \uD569\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: RecoveryRoom.CopingPlan.04
    trigger: "\uB300\uCC98 \uC804\uB7B5 \uD568\uAED8 \uB9CC\uB4E4\uAE30"
    stage: 4
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 0
    teacherGoals: 0300000005000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uB300\uCC98 \uC804\uB7B5 \uD568\uAED8 \uB9CC\uB4E4\uAE30"
      studentLine: "\uB2E4\uC74C\uC5D0\uB3C4 \uB610 \uADF8\uB7EC\uBA74\u2026 \uC800\uB3C4 \uC5B4\uB5BB\uAC8C \uD574\uC57C \uD560\uC9C0 \uBAA8\uB974\uACA0\uC5B4\uC694."
      observation: "\uCC98\uC74C\uC73C\uB85C \uAD50\uC0AC \uCABD\uC73C\uB85C \uBAB8\uC744 \uB3CC\uB9BD\uB2C8\uB2E4. \uB3C4\uC6C0\uC744 \uBC1B\uC544\uB4E4\uC77C \uC900\uBE44 \uC2E0\uD638\uC785\uB2C8\uB2E4."
      entryGesture: 10
      gestureIntensity: 0.5
      options:
      - label: "\uD559\uC0DD\uC774 \uACE0\uB97C \uC218 \uC788\uB294 \uC804\uB7B5 \uBAA9\uB85D\uC744 \uD568\uAED8 \uB9CC\uB4E0\uB2E4"
        spokenResponse: "\uB2E4\uC74C\uC5D0 \uADF8\uB7F0 \uC21C\uAC04\uC774 \uC624\uBA74 \uC4F8 \uC218 \uC788\uB294 \uBC29\uBC95\uC744 \uAC19\uC774 \uB450\uC138 \uAC1C \uB9CC\uB4E4\uC5B4 \uBCF4\uC790. \uB124\uAC00 \uC81C\uC77C \uD560 \uB9CC\uD55C \uAC78 \uACE8\uB77C."
        quality: 3
        rationale: "\uACF5\uB3D9 \uC804\uB7B5 \uC218\uB9BD\uACFC \uC120\uD0DD\uAD8C: \uAD50\uC0AC\uAC00 \uCC98\uBC29\uD558\uC9C0 \uC54A\uACE0 \uD559\uC0DD\uC774 \uC2E4\uD589 \uAC00\uB2A5\uD55C \uB300\uCC98\uB97C \uACE0\uB974\uAC8C \uD574 \uC790\uAE30\uD6A8\uB2A5\uAC10\uC744 \uC138\uC6C1\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uAD50\uC0AC\uAC00 \uC804\uB7B5\uC744 \uC815\uD574 \uC900\uB2E4"
        spokenResponse: "\uADF8\uB7F4 \uB550 \uBB34\uC870\uAC74 \uC2EC\uD638\uD761 \uC138 \uBC88 \uD558\uACE0 \uC120\uC0DD\uB2D8\uD55C\uD14C \uC640."
        quality: 2
        rationale: "\uBC29\uD5A5\uC740 \uB9DE\uC9C0\uB9CC \uB2E8\uC77C \uCC98\uBC29\uC740 \uC0C1\uD669\uC774 \uB2EC\uB77C\uC9C0\uBA74 \uBB34\uB108\uC9D1\uB2C8\uB2E4. \uD559\uC0DD\uC774 \uACE0\uB978 \uC804\uB7B5\uC774 \uC624\uB798 \uAC11\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC2A4\uC2A4\uB85C \uC54C\uC544\uB0B4\uB77C\uACE0 \uD55C\uB2E4"
        spokenResponse: "\uC774\uC81C \uACE0\uD559\uB144\uC774\uB2C8\uAE4C \uADF8 \uC815\uB3C4\uB294 \uC2A4\uC2A4\uB85C \uC0DD\uAC01\uD574 \uBD10\uC57C\uC9C0."
        quality: 1
        rationale: "\uC790\uC728 \uC694\uAD6C\uB294 \uC9C0\uC6D0 \uC2E0\uD638\uB97C \uAC70\uB46C\uB4E4\uC774\uB294 \uB9D0\uB85C \uB4E4\uB9BD\uB2C8\uB2E4. \uBC1C\uD310\uC744 \uD568\uAED8 \uB9CC\uB4E0 \uB4A4\uC5D0 \uC790\uC728\uC774 \uC635\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
  - scenarioId: RecoveryRoom.SignalPromise.05
    trigger: "\uC7AC\uBC1C \uC2E0\uD638\uC640 \uB3C4\uC6C0 \uC694\uCCAD \uC57D\uC18D"
    stage: 4
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 0
    teacherGoals: 0400000000000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uC7AC\uBC1C \uC2E0\uD638\uC640 \uB3C4\uC6C0 \uC694\uCCAD \uC57D\uC18D"
      studentLine: "\uC120\uC0DD\uB2D8\uC774 \uB9E4\uBC88 \uC54C\uC544\uCC4C \uC218\uB294 \uC5C6\uC796\uC544\uC694."
      observation: "\uD604\uC2E4\uC801\uC778 \uAC71\uC815\uC744 \uB9D0\uB85C \uD45C\uD604\uD569\uB2C8\uB2E4. \uB3C4\uC6C0 \uC694\uCCAD \uBC29\uBC95\uC744 \uC815\uD560 \uC2DC\uC810\uC785\uB2C8\uB2E4."
      entryGesture: 10
      gestureIntensity: 0.45
      options:
      - label: "\uB3C4\uC6C0 \uC694\uCCAD \uC2E0\uD638\uC640 \uC5F0\uACC4 \uACBD\uB85C\uB97C \uC815\uD55C\uB2E4"
        spokenResponse: "\uB9DE\uC544, \uADF8\uB798\uC11C \uC6B0\uB9AC\uB07C\uB9AC \uC2E0\uD638\uB97C \uC815\uD558\uC790. \uCC45\uC0C1\uC5D0 \uD30C\uB780 \uCE74\uB4DC\uB97C \uC62C\uB9AC\uBA74 \uB0B4\uAC00 \uC870\uC6A9\uD788 \uAC08\uAC8C. \uB9CE\uC774 \uD798\uB4E0 \uB0A0\uC740 \uC0C1\uB2F4 \uC120\uC0DD\uB2D8\uACFC \uC14B\uC774 \uC774\uC57C\uAE30\uD560 \uC218\uB3C4 \uC788\uC5B4."
        quality: 3
        rationale: "\uB3C4\uC6C0 \uC694\uCCAD \uC2E0\uD638\uC640 \uC5F0\uACC4 \uACBD\uB85C: \uD559\uC0DD \uC8FC\uB3C4\uC758 \uC2E0\uD638 \uCCB4\uACC4\uB97C \uB9CC\uB4E4\uACE0 \uC804\uBB38 \uC9C0\uC6D0 \uC5F0\uACB0\uC744 \uC790\uC5F0\uC2A4\uB7FD\uAC8C \uC608\uACE0\uD574 \uC548\uC804\uB9DD\uC744 \uB113\uD799\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uAC71\uC815\uC744 \uC77C\uCD95\uD55C\uB2E4"
        spokenResponse: "\uAC71\uC815 \uB9C8, \uC120\uC0DD\uB2D8\uC774 \uB2E4 \uBCF4\uACE0 \uC788\uC5B4."
        quality: 1
        rationale: "\uC548\uC2EC\uC2DC\uD0A4\uB824\uB294 \uC758\uB3C4\uC9C0\uB9CC \uADFC\uAC70 \uC5C6\uB294 \uC7A5\uB2F4\uC740 \uC2E0\uB8B0\uB97C \uC18C\uBAA8\uD569\uB2C8\uB2E4. \uAD6C\uCCB4\uC801\uC778 \uBC29\uBC95\uC774 \uC548\uC2EC\uC744 \uB9CC\uB4ED\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC7AC\uBC1C \uC2DC \uBD88\uC774\uC775\uC744 \uC608\uACE0\uD55C\uB2E4"
        spokenResponse: "\uB2E4\uC74C\uC5D0 \uB610 \uADF8\uB7EC\uBA74 \uADF8\uB54C\uB294 \uBD80\uBAA8\uB2D8\uAED8 \uC5F0\uB77D\uD560 \uAC70\uC57C."
        quality: 0
        rationale: "\uC704\uD611 \uAE30\uBC18 \uC608\uBC29\uC740 \uB3C4\uC6C0 \uC694\uCCAD\uC744 \uC228\uAE30\uAC8C \uB9CC\uB4E4\uC5B4 \uC7AC\uBC1C \uC2E0\uD638\uB97C \uC624\uD788\uB824 \uB193\uCE58\uAC8C \uD569\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: RecoveryRoom.ReentryPlan.06
    trigger: "\uAD50\uC2E4 \uBCF5\uADC0 \uB3D9\uD589 \uACC4\uD68D"
    stage: 5
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 0
    teacherGoals: 0500000004000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uAD50\uC2E4 \uBCF5\uADC0 \uB3D9\uD589 \uACC4\uD68D"
      studentLine: "\uB4E4\uC5B4\uAC00\uBA74\u2026 \uC560\uB4E4\uC774 \uB2E4 \uCCD0\uB2E4\uBCFC \uAC83 \uAC19\uC544\uC694."
      observation: "\uBAB8\uC740 \uC548\uC815\uB410\uC9C0\uB9CC \uBB38 \uC55E\uC5D0\uC11C \uBC1C\uAC78\uC74C\uC774 \uB290\uB824\uC9D1\uB2C8\uB2E4. \uBCF5\uADC0 \uC7A5\uBA74\uC5D0 \uB300\uD55C \uBD80\uB2F4\uC774 \uB0A8\uC544 \uC788\uC2B5\uB2C8\uB2E4."
      entryGesture: 11
      gestureIntensity: 0.5
      options:
      - label: "\uBCF5\uADC0 \uC808\uCC28\uB97C \uC791\uAC8C \uC124\uACC4\uD558\uACE0 \uB3D9\uD589\uD55C\uB2E4"
        spokenResponse: "\uAC19\uC774 \uB4E4\uC5B4\uAC00\uC790. \uC544\uBB34 \uC124\uBA85 \uC548 \uD574\uB3C4 \uB3FC. \uB124 \uC790\uB9AC\uB85C \uBC14\uB85C \uAC00\uC11C \uD558\uB358 \uD65C\uB3D9\uBD80\uD130 \uD558\uBA74 \uB3FC. \uB0B4\uAC00 \uBA3C\uC800 \uB4E4\uC5B4\uAC08\uAC8C."
        quality: 3
        rationale: "\uBCF5\uADC0 \uC808\uCC28 \uAD6C\uC870\uD654\uC640 \uB3D9\uD589: \uC8FC\uBAA9\uC744 \uCD5C\uC18C\uD654\uD558\uB294 \uC9C4\uC785 \uACBD\uB85C\uB97C \uBBF8\uB9AC \uADF8\uB824 \uC8FC\uACE0 \uAD50\uC0AC\uAC00 \uC55E\uC7A5\uC11C \uBCF5\uADC0 \uBD80\uB2F4\uC744 \uB098\uB215\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC900\uBE44\uB420 \uB54C\uAE4C\uC9C0 \uB354 \uC788\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uBD80\uB2F4\uB418\uBA74 \uC624\uB298\uC740 \uC5EC\uAE30 \uB354 \uC788\uC5B4\uB3C4 \uB3FC."
        quality: 2
        rationale: "\uBC30\uB824\uC9C0\uB9CC \uBCF5\uADC0 \uC5C6\uB294 \uC548\uC815\uC740 \uD68C\uD53C\uB97C \uAC15\uD654\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC791\uC740 \uBCF5\uADC0 \uB2E8\uACC4\uB97C \uD568\uAED8 \uC815\uD558\uB294 \uD3B8\uC774 \uB0AB\uC2B5\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uACF5\uAC1C \uC0AC\uACFC\uB85C \uB9C8\uBB34\uB9AC\uD558\uB824 \uD55C\uB2E4"
        spokenResponse: "\uB4E4\uC5B4\uAC00\uC11C \uC544\uAE4C \uC77C\uC740 \uCE5C\uAD6C\uB4E4\uC5D0\uAC8C \uC0AC\uACFC\uD558\uACE0 \uC2DC\uC791\uD558\uC790."
        quality: 1
        rationale: "\uBCF5\uADC0 \uC9C1\uC804\uC758 \uACF5\uAC1C \uC0AC\uACFC \uC694\uAD6C\uB294 \uC548\uC815 \uACF5\uAC04\uC5D0\uC11C \uB9CC\uB4E0 \uC2E0\uB8B0\uB97C \uBB38 \uC55E\uC5D0\uC11C \uBB34\uB108\uB728\uB9BD\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
