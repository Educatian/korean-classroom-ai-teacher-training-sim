      studentLine: "\uC544\uBB34\uB3C4 \uC81C \uB9D0\uC744 \uC548 \uB4E3\uC796\uC544\uC694!"
      observation: "\uC190\uBC14\uB2E5\uC73C\uB85C \uCC45\uC0C1\uC744 \uB450\uB4DC\uB9AC\uACE0
        \uBAA9\uC18C\uB9AC\uAC00 \uCEE4\uC9D1\uB2C8\uB2E4."
      entryGesture: 0
      gestureIntensity: 0
      options:
      - label: "\uAC70\uB9AC\uB97C \uB450\uACE0 \uC9E7\uAC8C \uC548\uC804\uC744 \uD655\uC778\uD55C\uB2E4"
        spokenResponse: "\uB124 \uB9D0\uC744 \uB4E3\uACE0 \uC788\uC5B4. \uC190\uC740
          \uC7A0\uAE50 \uB0B4\uB824\uB193\uACE0, \uC5EC\uAE30\uC11C \uB9D0\uD560\uC9C0
          \uC870\uC6A9\uD55C \uACF3\uC5D0\uC11C \uB9D0\uD560\uC9C0 \uACE8\uB77C\uC918."
        quality: 3
        rationale: "\uC815\uC11C \uC548\uC815\uACFC \uC874\uC5C4, \uC120\uD0DD\uAD8C,
          \uC548\uC804, \uBCF5\uADC0 \uACBD\uB85C\uB97C \uD568\uAED8 \uC9C0\uC6D0\uD569\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uD070 \uBAA9\uC18C\uB9AC\uB85C \uC81C\uC555\uD55C\uB2E4"
        spokenResponse: "\uADF8\uB9CC \uC18C\uB9AC \uC9C8\uB7EC!"
        quality: 0
        rationale: "\uACF5\uAC1C\uC801 \uD1B5\uC81C\uC640 \uC555\uBC15\uC740 \uC704\uAE30
          \uAC15\uB3C4\uB97C \uB192\uC77C \uC218 \uC788\uC2B5\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
      - label: "\uCE5C\uAD6C\uB4E4 \uC55E\uC5D0\uC11C \uC0AC\uACFC\uB97C \uC694\uAD6C\uD55C\uB2E4"
        spokenResponse: "\uBAA8\uB450\uC5D0\uAC8C \uC9C0\uAE08 \uC0AC\uACFC\uD574."
        quality: 1
        rationale: "\uC758\uB3C4\uB294 \uC774\uD574\uB418\uC9C0\uB9CC \uB192\uC740
