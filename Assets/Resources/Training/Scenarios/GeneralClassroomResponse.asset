  scenarioId: GeneralClassroomResponse
  displayName: "\uC77C\uBC18 \uAD50\uC2E4 \uC815\uC11C\u00B7\uD589\uB3D9 \uC704\uAE30 \uB300\uC751"
  sceneId: 1
  researchNotes: "\uBE44\uD2B8 \uD14D\uC2A4\uD2B8, \uB300\uC751 \uC120\uD0DD\uC9C0, \uC5ED\uB7C9 \uBAA9\uD45C\uB294 \uC774 \uC5D0\uC14B\uC758 Inspector\uC5D0\uC11C \uC9C1\uC811 \uC218\uC815\uD569\uB2C8\uB2E4."
  beats:
  - scenarioId: GeneralClassroom.WorkloadFreeze.01
    trigger: "\uACFC\uC81C \uACFC\uBD80\uD558\uC640 \uAC70\uBD80"
    stage: 0
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 0
    teacherGoals: 0200000003000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uACFC\uC81C \uACFC\uBD80\uD558\uC640 \uAC70\uBD80"
      studentLine: "\uBB38\uC81C\uAC00 \uB108\uBB34 \uB9CE\uC544\uC694. \uB354\uB294
        \uBABB \uD558\uACA0\uC5B4\uC694."
      observation: "\uC8FC\uBA39\uC744 \uC950\uACE0 \uC2DC\uC120\uC744 \uD53C\uD558\uBA70
        \uD638\uD761\uC774 \uBE68\uB77C\uC9D1\uB2C8\uB2E4."
      entryGesture: 1
      gestureIntensity: 0.6
      options:
      - label: "\uAC10\uC815\uC744 \uC778\uC815\uD558\uACE0 \uC26C\uB294 \uC120\uD0DD\uC744
          \uC900\uB2E4"
        spokenResponse: "\uC9C0\uAE08 \uB9CE\uC774 \uBC85\uCC2C \uAC83 \uAC19\uC544.
          \uC5EC\uAE30\uC11C \uC7A0\uAE50 \uC26C\uAC70\uB098 \uB4A4\uCABD \uC548\uC815
          \uC790\uB9AC\uB85C \uC774\uB3D9\uD574\uB3C4 \uAD1C\uCC2E\uC544."
        quality: 3
        rationale: "\uAC10\uC815 \uBC18\uC601\uACFC \uC120\uD0DD\uAD8C \uC81C\uACF5: \uBC85\uCC2C \uC0C1\uD0DC\uB97C \uBA3C\uC800 \uB9D0\uB85C \uC778\uC815\uD558\uACE0 \uC26C\uAE30\uC640 \uC790\uB9AC \uC774\uB3D9\uC774\uB77C\uB294 \uC2E4\uD589 \uAC00\uB2A5\uD55C \uC120\uD0DD\uC744 \uC8FC\uC5B4 \uAC01\uC131\uC744 \uB0AE\uCD94\uACE0 \uAD00\uACC4\uB97C \uC720\uC9C0\uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC989\uC2DC \uACFC\uC81C \uC644\uB8CC\uB97C \uC694\uAD6C\uD55C\uB2E4"
        spokenResponse: "\uC218\uC5C5 \uC911\uC774\uC57C. \uC9C0\uAE08 \uBC14\uB85C
          \uB05D\uB0B4."
        quality: 0
        rationale: "\uC989\uC2DC \uC644\uC218 \uC694\uAD6C\uB294 \uACFC\uBD80\uD558 \uC0C1\uD0DC\uC758 \uC555\uBC15\uC744 \uD0A4\uC6CC \uAC70\uBD80\uB97C \uAC15\uD654\uD558\uAE30 \uC27D\uC2B5\uB2C8\uB2E4. \uAC10\uC815 \uC778\uC815 \uC5C6\uC774 \uC694\uAD6C\uB9CC \uB0A8\uC544 \uC704\uAE30 \uAC15\uB3C4\uAC00 \uC62C\uB77C\uAC11\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
      - label: "\uC6D0\uC778\uC744 \uC5F0\uC18D\uD574\uC11C \uBB3B\uB294\uB2E4"
        spokenResponse: "\uC65C \uADF8\uB798? \uBB34\uC2A8 \uC77C\uC774\uC57C? \uC544\uCE68\uC5D0
          \uBB34\uC2A8 \uC77C \uC788\uC5C8\uC5B4?"
        quality: 1
        rationale: "\uC5F0\uC18D \uC9C8\uBB38\uC740 \uAD00\uC2EC\uC758 \uD45C\uD604\uC774\uC9C0\uB9CC \uACFC\uAC01\uC131 \uC0C1\uD0DC\uC5D0\uC11C\uB294 \uCC98\uB9AC \uBD80\uB2F4\uC744 \uB354\uD569\uB2C8\uB2E4. \uC9E7\uC740 \uC778\uC815 \uD6C4 \uCC98\uB9AC \uC2DC\uAC04\uC744 \uC8FC\uB294 \uD3B8\uC774 \uD6A8\uACFC\uC801\uC785\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: GeneralClassroom.DeskTapEscalation.02
    trigger: "\uBD84\uB178 \uC0C1\uC2B9\uACFC \uCC45\uC0C1 \uB450\uB4DC\uB9AC\uAE30"
    stage: 1
    studentPersona: {fileID: 11400000, guid: f4a8add639795e14b8aeb9ff20ec000b, type: 2}
    crisisType: 1
    teacherGoals: 0100000004000000
    safetyFlags: 0100000002000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uBD84\uB178 \uC0C1\uC2B9\uACFC \uCC45\uC0C1 \uB450\uB4DC\uB9AC\uAE30"
      studentLine: "\uC544\uBB34\uB3C4 \uC81C \uB9D0\uC744 \uC548 \uB4E3\uC796\uC544\uC694!"
      observation: "\uC190\uBC14\uB2E5\uC73C\uB85C \uCC45\uC0C1\uC744 \uB450\uB4DC\uB9AC\uACE0
        \uBAA9\uC18C\uB9AC\uAC00 \uCEE4\uC9D1\uB2C8\uB2E4."
      entryGesture: 6
      gestureIntensity: 0.78
      options:
      - label: "\uAC70\uB9AC\uB97C \uB450\uACE0 \uC9E7\uAC8C \uC548\uC804\uC744 \uD655\uC778\uD55C\uB2E4"
        spokenResponse: "\uB124 \uB9D0\uC744 \uB4E3\uACE0 \uC788\uC5B4. \uC190\uC740
          \uC7A0\uAE50 \uB0B4\uB824\uB193\uACE0, \uC5EC\uAE30\uC11C \uB9D0\uD560\uC9C0
          \uC870\uC6A9\uD55C \uACF3\uC5D0\uC11C \uB9D0\uD560\uC9C0 \uACE8\uB77C\uC918."
        quality: 3
        rationale: "\uB0AE\uC740 \uC790\uADF9\uC758 \uC548\uC804 \uD655\uC778\uACFC \uC120\uD0DD\uAD8C: \uACBD\uCCAD\uC744 \uD45C\uBA85\uD558\uACE0 \uC190 \uB3D9\uC791\uC744 \uC9E7\uAC8C \uC548\uC804 \uD655\uC778\uD55C \uB4A4 \uB9D0\uD560 \uC7A5\uC18C\uB97C \uACE0\uB974\uAC8C \uD574 \uD798\uACA8\uB8E8\uAE30 \uC5C6\uC774 \uAC01\uC131\uC744 \uB0AE\uCDA5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uD070 \uBAA9\uC18C\uB9AC\uB85C \uC81C\uC555\uD55C\uB2E4"
        spokenResponse: "\uADF8\uB9CC \uC18C\uB9AC \uC9C8\uB7EC!"
        quality: 0
        rationale: "\uD070 \uBAA9\uC18C\uB9AC \uC81C\uC555\uC740 \uC790\uADF9 \uC218\uC900\uC744 \uD568\uAED8 \uC62C\uB824 \uC0C1\uD638 \uACA9\uC559\uC744 \uB9CC\uB4E4\uAE30 \uC27D\uC2B5\uB2C8\uB2E4. \uACF5\uAC1C\uC801 \uD1B5\uC81C\uB294 \uC874\uC5C4\uC744 \uD6FC\uC190\uD574 \uD68C\uBCF5\uC744 \uB2A6\uCDA5\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
      - label: "\uCE5C\uAD6C\uB4E4 \uC55E\uC5D0\uC11C \uC0AC\uACFC\uB97C \uC694\uAD6C\uD55C\uB2E4"
        spokenResponse: "\uBAA8\uB450\uC5D0\uAC8C \uC9C0\uAE08 \uC0AC\uACFC\uD574."
        quality: 1
        rationale: "\uACF5\uAC1C \uC0AC\uACFC \uC694\uAD6C\uB294 \uAC08\uB4F1 \uC815\uB9AC\uCC98\uB7FC \uBCF4\uC774\uC9C0\uB9CC \uB610\uB798 \uC55E \uCCB4\uBA74 \uC190\uC0C1\uC73C\uB85C \uBD84\uB178\uB97C \uC7AC\uC810\uD654\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC9C4\uC815 \uC774\uD6C4 \uBE44\uACF5\uAC1C\uB85C \uB2E4\uB8E8\uB294 \uAC83\uC774 \uC548\uC804\uD569\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: GeneralClassroom.PanicRecovery.03
    trigger: "\uBD88\uC548\uACFC \uACFC\uD638\uD761"
    stage: 2
    studentPersona: {fileID: 11400000, guid: d7a6f52259749ea48a58e43483faf0a7, type: 2}
    crisisType: 2
    teacherGoals: 0200000004000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uBD88\uC548\uACFC \uACFC\uD638\uD761"
      studentLine: "\uC228\uC774 \uC798 \uC548 \uC26C\uC5B4\uC838\uC694. \uB098\uAC00\uACE0
        \uC2F6\uC5B4\uC694."
      observation: "\uC5B4\uAE68\uAC00 \uC62C\uB77C\uAC00\uACE0 \uC9E7\uACE0 \uBE60\uB978
        \uD638\uD761\uC744 \uBC18\uBCF5\uD569\uB2C8\uB2E4."
      entryGesture: 7
      gestureIntensity: 0.62
      options:
      - label: "\uD638\uD761\uC744 \uAC15\uC694\uD558\uC9C0 \uC54A\uACE0 \uCD9C\uAD6C
          \uC120\uD0DD\uC744 \uC81C\uACF5\uD55C\uB2E4"
        spokenResponse: "\uC54C\uACA0\uC5B4. \uBB38 \uAC00\uAE4C\uC6B4 \uC790\uB9AC\uC640
          \uBCF5\uB3C4 \uC548\uC815 \uACF5\uAC04 \uC911 \uD3B8\uD55C \uACF3\uC73C\uB85C
          \uAC19\uC774 \uC774\uB3D9\uD558\uC790."
        quality: 3
        rationale: "\uCD9C\uAD6C \uC120\uD0DD \uC81C\uACF5\uACFC \uB3D9\uD589: \uD638\uD761\uC744 \uC9C0\uC2DC\uD558\uC9C0 \uC54A\uACE0 \uC548\uC804\uD55C \uC774\uB3D9 \uC120\uD0DD\uC9C0\uB97C \uD568\uAED8 \uC2E4\uD589\uD574 \uD1B5\uC81C\uAC10\uC744 \uB3CC\uB824\uC8FC\uBA74\uC11C \uAC01\uC131\uC744 \uB0AE\uCDA5\uB2C8\uB2E4."
        resultingAffect: 4
        competencyEvidence: []
      - label: "\uC9C4\uC815\uD558\uB77C\uACE0 \uBC18\uBCF5\uD55C\uB2E4"
        spokenResponse: "\uC9C4\uC815\uD574. \uC228 \uD06C\uAC8C \uC26C\uBA74 \uB418\uC796\uC544."
        quality: 1
        rationale: "\uC9C4\uC815\uD558\uB77C\uB294 \uBC18\uBCF5\uC740 \uC758\uB3C4\uB294 \uC774\uD574\uB418\uB098 \uBD88\uC548 \uC0C1\uD0DC\uC5D0\uC11C \uC9C0\uC2DC\uB85C \uB4E4\uB824 \uD1B5\uC81C\uAC10\uC744 \uB354 \uBE7C\uC557\uAE30 \uC27D\uC2B5\uB2C8\uB2E4. \uC120\uD0DD \uAC00\uB2A5\uD55C \uB300\uC548 \uC81C\uC2DC\uAC00 \uD544\uC694\uD569\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
      - label: "\uC218\uC5C5 \uBC29\uD574\uB85C \uC9C0\uC801\uD55C\uB2E4"
        spokenResponse: "\uB2E4\uB978 \uD559\uC0DD\uB4E4 \uC218\uC5C5\uC744 \uBC29\uD574\uD558\uACE0
          \uC788\uC5B4."
        quality: 0
        rationale: "\uC218\uC5C5 \uBC29\uD574 \uC9C0\uC801\uC740 \uBD88\uC548\uC744 \uC798\uBABB\uB41C \uD589\uB3D9\uC73C\uB85C \uADDC\uC815\uD574 \uC218\uCE58\uC2EC\uC744 \uB354\uD569\uB2C8\uB2E4. \uC2E0\uCCB4 \uC2E0\uD638\uAC00 \uD070 \uC2DC\uC810\uC5D0\uB294 \uC548\uC804\uACFC \uC548\uC815\uC774 \uC6B0\uC120\uC785\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
  - scenarioId: GeneralClassroom.ReentryRefusal.04
    trigger: "\uB610\uB798 \uAC08\uB4F1 \uC9C1\uD6C4"
    stage: 1
    studentPersona: {fileID: 11400000, guid: e63e73c2eae702f47adb928e3d854dff, type: 2}
    crisisType: 5
    teacherGoals: 0000000005000000
    safetyFlags: 04000000
    peerAttention: 1
    presentationAvoidance: 0
    beat:
      title: "\uB610\uB798 \uAC08\uB4F1 \uC9C1\uD6C4"
      studentLine: "\uC7E4\uAC00 \uBA3C\uC800 \uB180\uB838\uC5B4\uC694. \uC800\uB9CC
        \uD63C\uB0B4\uC9C0 \uB9C8\uC138\uC694."
      observation: "\uC0C1\uB300 \uD559\uC0DD\uC744 \uAC00\uB9AC\uD0A4\uBA70 \uBAB8\uC744
        \uC55E\uC73C\uB85C \uAE30\uC6B8\uC785\uB2C8\uB2E4."
      entryGesture: 4
      gestureIntensity: 0.6
      options:
      - label: "\uBD84\uB9AC \uD6C4 \uC591\uCABD \uC774\uC57C\uAE30\uB97C \uBE44\uACF5\uAC1C\uB85C
          \uB4E3\uB294\uB2E4"
        spokenResponse: "\uC9C0\uAE08\uC740 \uC11C\uB85C \uAC70\uB9AC\uB97C \uB450\uC790.
          \uB124 \uC774\uC57C\uAE30\uB294 \uC7A0\uC2DC \uD6C4 \uC870\uC6A9\uD55C
          \uACF3\uC5D0\uC11C \uB530\uB85C \uB4E4\uC744\uAC8C."
        quality: 3
        rationale: "\uBD84\uB9AC\uC640 \uBE44\uACF5\uAC1C \uCCAD\uCDE8 \uC57D\uC18D: \uBB3C\uB9AC\uC801 \uAC70\uB9AC\uB97C \uBA3C\uC800 \uD655\uBCF4\uD558\uACE0 \uAC01\uC790\uC758 \uC774\uC57C\uAE30\uB97C \uB530\uB85C \uB4E3\uAE30\uB85C \uC57D\uC18D\uD574 \uAC08\uB4F1 \uD655\uC0B0\uACFC \uACF5\uAC1C \uC2EC\uD310\uC744 \uD53C\uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC989\uC2DC \uC798\uC798\uBABB\uC744 \uD310\uC815\uD55C\uB2E4"
        spokenResponse: "\uB0B4\uAC00 \uBD24\uC5B4. \uB124\uAC00 \uBA3C\uC800 \uD588\uC796\uC544."
        quality: 0
        rationale: "\uC989\uC2DC \uC798\uC798\uBABB \uD310\uC815\uC740 \uD55C\uCABD\uC744 \uACF5\uAC1C\uC801\uC73C\uB85C \uD328\uC790\uB85C \uB9CC\uB4E4\uC5B4 \uBD84\uB178\uC640 \uBD88\uC2E0\uC744 \uD0A4\uC6C1\uB2C8\uB2E4. \uC0AC\uC2E4 \uD655\uC778\uC740 \uC9C4\uC815 \uC774\uD6C4 \uBE44\uACF5\uAC1C\uB85C \uD574\uC57C \uD569\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
      - label: "\uB458\uC774 \uC54C\uC544\uC11C \uD574\uACB0\uD558\uAC8C \uD55C\uB2E4"
        spokenResponse: "\uB458\uC774\uC11C \uD654\uD574\uD558\uACE0 \uB4E4\uC5B4\uC640."
        quality: 1
        rationale: "\uC790\uC728 \uD574\uACB0 \uC704\uC784\uC740 \uAC08\uB4F1 \uC9C1\uD6C4\uC758 \uB192\uC740 \uAC01\uC131 \uC0C1\uD0DC\uC5D0\uC11C\uB294 \uBC29\uC784\uC774 \uB418\uAE30 \uC27D\uC2B5\uB2C8\uB2E4. \uBD84\uB9AC\uC640 \uC7AC\uC811\uCD09 \uAD6C\uC870\uB97C \uAD50\uC0AC\uAC00 \uBA3C\uC800 \uC81C\uACF5\uD574\uC57C \uD569\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
