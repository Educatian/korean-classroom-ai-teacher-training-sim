  beats:
  - scenarioId: GeneralClassroom.WorkloadFreeze.01
    trigger: "\uACFC\uC81C \uACFC\uBD80\uD558\uC640 \uAC70\uBD80"
    stage: 0
    studentPersona: {fileID: 11400000, guid: 730ce778f98482345aed9deef3e81f5e, type: 2}
    crisisType: 0
    teacherGoals: 0200000003000000
    safetyFlags: 00000000
    peerAttention: 0
    presentationAvoidance: 0
    beat:
      title: "\uACFC\uC81C \uACFC\uBD80\uD558\uC640 \uAC70\uBD80"
      studentLine: "\uBB38\uC81C\uAC00 \uB108\uBB34 \uB9CE\uC544\uC694. \uB354\uB294
        \uBABB \uD558\uACA0\uC5B4\uC694."
      observation: "\uC8FC\uBA39\uC744 \uC950\uACE0 \uC2DC\uC120\uC744 \uD53C\uD558\uBA70
        \uD638\uD761\uC774 \uBE68\uB77C\uC9D1\uB2C8\uB2E4."
      entryGesture: 0
      gestureIntensity: 0
      options:
      - label: "\uAC10\uC815\uC744 \uC778\uC815\uD558\uACE0 \uC26C\uB294 \uC120\uD0DD\uC744
          \uC900\uB2E4"
        spokenResponse: "\uC9C0\uAE08 \uB9CE\uC774 \uBC85\uCC2C \uAC83 \uAC19\uC544.
          \uC5EC\uAE30\uC11C \uC7A0\uAE50 \uC26C\uAC70\uB098 \uB4A4\uCABD \uC548\uC815
          \uC790\uB9AC\uB85C \uC774\uB3D9\uD574\uB3C4 \uAD1C\uCC2E\uC544."
        quality: 3
        rationale: "\uC815\uC11C \uC548\uC815\uACFC \uC874\uC5C4, \uC120\uD0DD\uAD8C,
          \uC548\uC804, \uBCF5\uADC0 \uACBD\uB85C\uB97C \uD568\uAED8 \uC9C0\uC6D0\uD569\uB2C8\uB2E4."
        resultingAffect: 1
        competencyEvidence: []
      - label: "\uC989\uC2DC \uACFC\uC81C \uC644\uB8CC\uB97C \uC694\uAD6C\uD55C\uB2E4"
        spokenResponse: "\uC218\uC5C5 \uC911\uC774\uC57C. \uC9C0\uAE08 \uBC14\uB85C
          \uB05D\uB0B4."
        quality: 0
        rationale: "\uACF5\uAC1C\uC801 \uD1B5\uC81C\uC640 \uC555\uBC15\uC740 \uC704\uAE30
          \uAC15\uB3C4\uB97C \uB192\uC77C \uC218 \uC788\uC2B5\uB2C8\uB2E4."
        resultingAffect: 3
        competencyEvidence: []
      - label: "\uC6D0\uC778\uC744 \uC5F0\uC18D\uD574\uC11C \uBB3B\uB294\uB2E4"
        spokenResponse: "\uC65C \uADF8\uB798? \uBB34\uC2A8 \uC77C\uC774\uC57C? \uC544\uCE68\uC5D0
          \uBB34\uC2A8 \uC77C \uC788\uC5C8\uC5B4?"
        quality: 1
        rationale: "\uC758\uB3C4\uB294 \uC774\uD574\uB418\uC9C0\uB9CC \uB192\uC740
          \uAC01\uC131 \uC0C1\uD0DC\uC5D0\uC11C \uBD80\uB2F4\uC774\uB098 \uD68C\uD53C\uB97C
          \uD0A4\uC6B8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
        resultingAffect: 2
        competencyEvidence: []
  - scenarioId: GeneralClassroom.DeskTapEscalation.02
    trigger: "\uBD84\uB178 \uC0C1\uC2B9\uACFC \uCC45\uC0C1 \uB450\uB4DC\uB9AC\uAE30"
