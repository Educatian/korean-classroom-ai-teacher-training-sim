  stagePrompts:
  - stage: 0
    observationCue: "\uD559\uC0DD\uC758 \uB9D0\uB9CC \uB4E3\uC9C0 \uB9D0\uACE0 \uC2DC\uC120,
      \uC790\uC138, \uC190\uC758 \uAE34\uC7A5\uACFC \uACFC\uC81C \uD68C\uD53C \uC2E0\uD638\uB97C
      \uBA3C\uC800 \uC0B4\uD3B4\uBCF4\uC138\uC694."
    principleCue: "\uD589\uB3D9\uC744 \uBC14\uB85C \uAD50\uC815\uD558\uAE30\uBCF4\uB2E4
      \uAD00\uCC30\uB41C \uC5B4\uB824\uC6C0\uC744 \uB0AE\uC740 \uBAA9\uC18C\uB9AC\uB85C
      \uD655\uC778\uD569\uB2C8\uB2E4."
  - stage: 1
    observationCue: "\uBAA9\uC18C\uB9AC \uD06C\uAE30, \uC6C0\uC9C1\uC784, \uB610\uB798\uC758
      \uC2DC\uC120\uC774 \uD559\uC0DD\uC758 \uC790\uADF9\uC744 \uB354 \uB192\uC774\uACE0
      \uC788\uB294\uC9C0 \uC0B4\uD3B4\uBCF4\uC138\uC694."
    principleCue: "\uC694\uAD6C\uB97C \uBC18\uBCF5\uD558\uAE30\uBCF4\uB2E4 \uC790\uADF9\uC744
      \uB0AE\uCD94\uACE0 \uCC98\uB9AC\uD560 \uC2DC\uAC04\uC744 \uC81C\uACF5\uD569\uB2C8\uB2E4."
  - stage: 2
    observationCue: "\uC9C0\uAE08\uC740 \uC124\uBA85\uBCF4\uB2E4 \uC548\uC804\uAC70\uB9AC,
      \uC8FC\uBCC0 \uD559\uC0DD, \uB2E4\uCE60 \uAC00\uB2A5\uC131\uC744 \uC6B0\uC120
      \uD655\uC778\uD560 \uB2E8\uACC4\uC785\uB2C8\uB2E4."
    principleCue: "\uC9E7\uACE0 \uC608\uCE21 \uAC00\uB2A5\uD55C \uC5B8\uC5B4\uB85C
      \uC548\uC804\uC744 \uD655\uBCF4\uD558\uACE0 \uACF5\uAC1C\uC801\uC778 \uB300\uCE58\uB97C
      \uD53C\uD569\uB2C8\uB2E4."
  - stage: 3
    observationCue: "\uD638\uD761, \uC2DC\uC120, \uC190\uC758 \uD798\uC774 \uB290\uC2A8\uD574\uC9C0\uB294
      \uC791\uC740 \uC9C4\uC815 \uC2E0\uD638\uB97C \uAE30\uB2E4\uB824 \uBCF4\uC138\uC694."
    principleCue: "\uC11C\uB450\uB974\uC9C0 \uB9D0\uACE0 \uD559\uC0DD\uC774 \uD1B5\uC81C\uAC10\uC744
      \uB418\uCC3E\uC744 \uC218 \uC788\uB294 \uC791\uC740 \uC120\uD0DD\uAD8C\uC744
      \uC81C\uACF5\uD569\uB2C8\uB2E4."
  - stage: 4
    observationCue: "\uD559\uC0DD\uC774 \uC790\uC2E0\uC758 \uACBD\uD5D8\uC744 \uC124\uBA85\uD558\uB824\uB294\uC9C0,
      \uC5EC\uC804\uD788 \uBC29\uC5B4\uD558\uACE0 \uC788\uB294\uC9C0 \uAD6C\uBD84\uD574
      \uBCF4\uC138\uC694."
    principleCue: "\uC6D0\uC778\uC744 \uCD94\uAD81\uD558\uAE30\uBCF4\uB2E4 \uD559\uC0DD\uC774
      \uC774\uD574\uBC1B\uC558\uB2E4\uACE0 \uB290\uB07C\uB294\uC9C0 \uBA3C\uC800
      \uD655\uC778\uD569\uB2C8\uB2E4."
  - stage: 5
    observationCue: "\uC644\uC804\uD55C \uBCF5\uADC0\uB97C \uC694\uAD6C\uD558\uAE30
      \uC804\uC5D0 \uD559\uC0DD\uC774 \uAC10\uB2F9\uD560 \uC218 \uC788\uB294 \uAC00\uC7A5
      \uC791\uC740 \uCC38\uC5EC \uB2E8\uACC4\uB97C \uCC3E\uC73C\uC138\uC694."
    principleCue: "\uBCF5\uADC0 \uC2DC\uAC04\uACFC \uACFC\uC81C\uB7C9\uC744 \uAD6C\uCCB4\uC801\uC778
      \uC120\uD0DD\uC73C\uB85C \uC81C\uC2DC\uD558\uACE0 \uD6C4\uC18D \uC9C0\uC6D0\uC744
      \uC5F0\uACB0\uD569\uB2C8\uB2E4."
