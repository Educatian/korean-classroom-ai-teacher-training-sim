  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC774 \uC2DC\uBBAC\uB808\uC774\uD130\uB294 \uAD50\uC0AC \uAD50\uC721
    \uC5F0\uAD6C\uB97C \uC704\uD55C \uD504\uB85C\uD1A0\uD0C0\uC785\uC785\uB2C8\uB2E4.\n\n\xB7
    \uD3C9\uAC00\uB294 \uC99D\uAC70\uC911\uC2EC\uC124\uACC4(ECD) \uAE30\uBC18\uC758
    \uACB0\uC815\uB860\uC801 \uADDC\uCE59\uC73C\uB85C\uB9CC \uC774\uB8E8\uC5B4\uC9C0\uBA70,
    \uC0DD\uC131\uD615 AI\uB294 \uD559\uC0DD \uC5F0\uAE30\uC640 \uC870\uC5B8\uC5D0\uB9CC
    \uC0AC\uC6A9\uB429\uB2C8\uB2E4.\n\xB7 \uBC1C\uD654 \uC6D0\uBB38\uC740 \uC800\uC7A5\uB418\uC9C0
    \uC54A\uC2B5\uB2C8\uB2E4. \uD574\uC2DC\uC640 \uAE38\uC774\uB9CC \uAE30\uB85D\uB429\uB2C8\uB2E4.\n\xB7
    \uCC38\uAC00\uC790\uB294 \uAC00\uBA85 \uCF54\uB4DC\uB85C\uB9CC \uC2DD\uBCC4\uB418\uBA70,
    \uC2DC\uC120 \uC6D0\uC790\uB8CC\uB294 \uBA85\uC2DC\uC801 \uB3D9\uC758 \uC2DC\uC5D0\uB9CC
    \uC218\uC9D1\uB429\uB2C8\uB2E4.\n\xB7 \uD6C8\uB828 \uC885\uB8CC \uD6C4 \uC815\uC11C
    \uADA4\uC801\xB7\uC5ED\uB7C9 \uC99D\uAC70\xB7\uAC1C\uC785 \uD0C0\uC784\uB77C\uC778\uC744
    \uB2F4\uC740 \uB514\uBE0C\uB9AC\uD551\uC774 \uC81C\uACF5\uB429\uB2C8\uB2E4.\n\n\uC774
    \uB3C4\uAD6C\uB294 \uC784\uC0C1\uC801 \uD310\uB2E8, \uD559\uAD50 \uC704\uAE30\uB300\uC751
    \uC808\uCC28, \uC804\uBB38 \uC0C1\uB2F4 \uC778\uB825 \uC5F0\uACC4\uB97C \uB300\uCCB4\uD558\uC9C0
    \uC54A\uC2B5\uB2C8\uB2E4."
